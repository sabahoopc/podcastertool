import { useState, useEffect } from "react";

const COLORS = {
  bg: "#0a0a0f", surface: "#12121a", card: "#1a1a26", border: "#2a2a3e",
  accent: "#c8a96e", accentDim: "#8a7048", accentGlow: "#c8a96e22",
  text: "#e8e4d8", textMuted: "#7a7890", textDim: "#4a4860",
  solo: "#4e9e8f", group: "#7e6db5", interview: "#c05c5c", success: "#4e9e6f",
};

const typeConfig = {
  solo: { label: "فردي", color: COLORS.solo, icon: "◎", desc: "مذيع واحد يقدم المحتوى بمفرده" },
  group: { label: "جماعي", color: COLORS.group, icon: "◈", desc: "أكثر من مذيع يناقشون موضوعاً" },
  interview: { label: "حواري", color: COLORS.interview, icon: "◇", desc: "استضافة ضيف والتحاور معه" },
};

const frequencyOptions = ["يومي", "أسبوعي", "نصف شهري", "شهري", "غير منتظم"];
const durationOptions = ["١٠–٢٠ دقيقة", "٢٠–٤٠ دقيقة", "٤٠–٦٠ دقيقة", "٦٠–٩٠ دقيقة", "أكثر من ٩٠ دقيقة"];
const STYLE_KEY = "podcast_studio_style_v3";
const EPISODES_KEY = "podcast_studio_episodes_v3";

const API_HEADERS = {
  "Content-Type": "application/json",
  "anthropic-dangerous-direct-browser-access": "true",
};

// ─── Helpers ──────────────────────────────────────────────────────────────────
const callClaude = async (system, userMsg, maxTokens = 4000) => {
  const res = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: API_HEADERS,
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: maxTokens,
      system,
      messages: [{ role: "user", content: userMsg }],
    }),
  });
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  const json = await res.json();
  return json.content?.filter(b => b.type === "text").map(b => b.text).join("\n") || "";
};

const getStyle = () => { try { return JSON.parse(localStorage.getItem(STYLE_KEY)) || null; } catch { return null; } };
const getEpisodes = () => { try { return JSON.parse(localStorage.getItem(EPISODES_KEY)) || []; } catch { return []; } };
const saveEpisode = (ep) => {
  const eps = getEpisodes();
  const idx = eps.findIndex(e => e.id === ep.id);
  if (idx >= 0) eps[idx] = ep; else eps.unshift(ep);
  localStorage.setItem(EPISODES_KEY, JSON.stringify(eps));
};

// ─── UI Components ────────────────────────────────────────────────────────────
function Label({ children, hint }) {
  return (
    <div style={{ marginBottom: "10px" }}>
      <span style={{ fontSize: "11px", letterSpacing: "0.14em", color: COLORS.textMuted, textTransform: "uppercase" }}>{children}</span>
      {hint && <span style={{ fontSize: "11px", color: COLORS.textDim, marginRight: "8px" }}>{hint}</span>}
    </div>
  );
}

function TInput({ value, onChange, placeholder, multiline, rows = 4 }) {
  const s = {
    width: "100%", background: COLORS.bg, border: `1px solid ${COLORS.border}`, borderRadius: "6px",
    padding: "12px 14px", color: COLORS.text, fontFamily: "'Noto Kufi Arabic',sans-serif",
    fontSize: "14px", outline: "none", resize: multiline ? "vertical" : "none",
    direction: "rtl", boxSizing: "border-box", lineHeight: "1.8",
  };
  return multiline
    ? <textarea value={value} onChange={e => onChange(e.target.value)} placeholder={placeholder} rows={rows} style={s} />
    : <input value={value} onChange={e => onChange(e.target.value)} placeholder={placeholder} style={s} />;
}

function TSelect({ value, onChange, options, placeholder }) {
  return (
    <select value={value} onChange={e => onChange(e.target.value)} style={{
      width: "100%", background: COLORS.bg, border: `1px solid ${COLORS.border}`, borderRadius: "6px",
      padding: "12px 14px", color: value ? COLORS.text : COLORS.textMuted,
      fontFamily: "'Noto Kufi Arabic',sans-serif", fontSize: "14px",
      outline: "none", direction: "rtl", cursor: "pointer", appearance: "none",
    }}>
      <option value="" disabled>{placeholder}</option>
      {options.map(o => <option key={o} value={o}>{o}</option>)}
    </select>
  );
}

function Btn({ children, onClick, color, disabled, variant = "fill", small, full }) {
  const base = color || COLORS.accent;
  return (
    <button onClick={onClick} disabled={disabled} style={{
      background: variant === "fill" ? base : "transparent",
      border: `1px solid ${variant === "fill" ? base : COLORS.border}`,
      borderRadius: "6px", color: variant === "fill" ? "#0a0a0f" : COLORS.textMuted,
      fontFamily: "'Noto Kufi Arabic',sans-serif", fontWeight: "700",
      fontSize: small ? "12px" : "14px", padding: small ? "7px 16px" : "12px 24px",
      cursor: disabled ? "not-allowed" : "pointer", opacity: disabled ? 0.4 : 1,
      transition: "opacity 0.15s", width: full ? "100%" : "auto",
    }}>{children}</button>
  );
}

function Card({ children, style }) {
  return <div style={{ background: COLORS.card, border: `1px solid ${COLORS.border}`, borderRadius: "12px", padding: "24px", ...style }}>{children}</div>;
}

function SectionTitle({ icon, title, subtitle }) {
  return (
    <div style={{ marginBottom: "28px" }}>
      <div style={{ fontSize: "20px", fontWeight: "700", color: COLORS.text, marginBottom: "4px" }}>{icon} {title}</div>
      {subtitle && <div style={{ color: COLORS.textMuted, fontSize: "13px" }}>{subtitle}</div>}
    </div>
  );
}

function OutputBox({ text, onCopy, copied, maxHeight = "420px" }) {
  return (
    <div>
      <div style={{ display: "flex", justifyContent: "flex-end", marginBottom: "8px" }}>
        <Btn variant="outline" small onClick={onCopy}>{copied ? "✓ تم النسخ" : "نسخ"}</Btn>
      </div>
      <div style={{
        background: COLORS.bg, border: `1px solid ${COLORS.border}`, borderRadius: "10px",
        padding: "20px", color: COLORS.text, fontSize: "14px", lineHeight: "2",
        direction: "rtl", whiteSpace: "pre-wrap", fontFamily: "'Noto Kufi Arabic',sans-serif",
        maxHeight, overflowY: "auto",
      }}>{text}</div>
    </div>
  );
}

function Spinner({ color }) {
  return (
    <div style={{ textAlign: "center", padding: "48px 0" }}>
      <div style={{
        width: "36px", height: "36px", border: `3px solid ${COLORS.border}`,
        borderTop: `3px solid ${color || COLORS.accent}`, borderRadius: "50%",
        animation: "spin 0.8s linear infinite", margin: "0 auto 16px",
      }} />
      <div style={{ color: COLORS.textMuted, fontSize: "13px" }}>جارٍ التوليد...</div>
      <style>{`@keyframes spin{to{transform:rotate(360deg)}}`}</style>
    </div>
  );
}

function TypeBadge({ type }) {
  const cfg = typeConfig[type];
  return (
    <span style={{
      display: "inline-flex", alignItems: "center", gap: "5px",
      background: `${cfg.color}20`, border: `1px solid ${cfg.color}`,
      borderRadius: "5px", padding: "3px 10px", color: cfg.color, fontSize: "12px", fontWeight: "700",
    }}>{cfg.icon} {cfg.label}</span>
  );
}

function StepDots({ current, total }) {
  return (
    <div style={{ display: "flex", gap: "5px", justifyContent: "center", marginBottom: "36px" }}>
      {Array.from({ length: total }).map((_, i) => (
        <div key={i} style={{
          width: i === current ? "24px" : "7px", height: "7px", borderRadius: "4px",
          background: i === current ? COLORS.accent : i < current ? COLORS.accentDim : COLORS.border,
          transition: "all 0.3s",
        }} />
      ))}
    </div>
  );
}

// ─── NAV ──────────────────────────────────────────────────────────────────────
