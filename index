  { id: "create", icon: "✦", label: "إنشاء" },
  { id: "production", icon: "◉", label: "الإنتاج" },
  { id: "marketing", icon: "◐", label: "التسويق" },
  { id: "episodes", icon: "▦", label: "حلقاتي" },
