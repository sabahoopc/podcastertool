    }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=Noto+Kufi+Arabic:wght@400;600;700&display=swap');
        * { box-sizing: border-box; }
        textarea:focus, input:focus, select:focus { border-color: #c8a96e !important; outline: none; }
        ::-webkit-scrollbar { width: 5px; }
        ::-webkit-scrollbar-track { background: #12121a; }
        ::-webkit-scrollbar-thumb { background: #2a2a3e; border-radius: 3px; }
        button { transition: opacity 0.15s; }
        button:hover:not(:disabled) { opacity: 0.82; }
      `}</style>

      {showStyle && <StyleModal onClose={() => { setShowStyle(false); checkStyle(); }} />}

      {/* Header */}
      <div style={{ width: "100%", maxWidth: "620px", marginBottom: "24px" }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start" }}>
          <div>
            <div style={{
              display: "inline-flex", alignItems: "center", gap: "8px",
              background: COLORS.surface, border: `1px solid ${COLORS.border}`,
              borderRadius: "100px", padding: "4px 14px", marginBottom: "12px",
            }}>
              <div style={{ width: "5px", height: "5px", borderRadius: "50%", background: COLORS.accent, boxShadow: `0 0 7px ${COLORS.accent}` }} />
              <span style={{ color: COLORS.textMuted, fontSize: "10px", letterSpacing: "0.12em" }}>PODCAST STUDIO</span>
            </div>
            <div style={{ fontSize: "22px", fontWeight: "700", color: COLORS.text, marginBottom: "2px" }}>استوديو البودكاست</div>
            <div style={{ color: COLORS.textMuted, fontSize: "12px" }}>من الفكرة إلى النشر</div>
          </div>
          <button onClick={() => setShowStyle(true)} style={{
            background: hasStyle ? COLORS.accentGlow : COLORS.surface,
            border: `1px solid ${hasStyle ? COLORS.accent : COLORS.border}`,
            borderRadius: "10px", padding: "10px 14px", cursor: "pointer",
            color: hasStyle ? COLORS.accent : COLORS.textMuted,
            fontFamily: "'Noto Kufi Arabic',sans-serif", fontWeight: "700",
            fontSize: "12px", textAlign: "center",
          }}>
            <div style={{ fontSize: "18px", marginBottom: "2px" }}>✦</div>
            <div>أسلوبي</div>
            <div style={{ fontSize: "9px", marginTop: "2px", opacity: 0.7 }}>{hasStyle ? "مفعّل" : "غير مُعدّ"}</div>
          </button>
        </div>

        {currentEpisode && (
          <div style={{
            marginTop: "12px", background: COLORS.surface, border: `1px solid ${COLORS.border}`,
            borderRadius: "8px", padding: "10px 14px",
            display: "flex", alignItems: "center", gap: "10px",
          }}>
            <div style={{ width: "6px", height: "6px", borderRadius: "50%", background: COLORS.success, flexShrink: 0 }} />
            <span style={{ color: COLORS.textMuted, fontSize: "12px" }}>الحلقة الحالية:</span>
            <span style={{ color: COLORS.text, fontSize: "12px", fontWeight: "600" }}>{currentEpisode.name}</span>
            <TypeBadge type={currentEpisode.type} />
          </div>
        )}
      </div>

      {/* Main Card */}
      <div style={{ width: "100%", maxWidth: "620px" }}>
        <div style={{ background: COLORS.surface, border: `1px solid ${COLORS.border}`, borderRadius: "14px", padding: "24px" }}>
          <Nav active={tab} onChange={setTab} />
          {tab === "create" && <CreateScreen onEpisodeReady={handleEpisodeReady} onNavigate={setTab} />}
          {tab === "production" && <ProductionScreen episode={currentEpisode} onNavigate={setTab} />}
          {tab === "marketing" && <MarketingScreen episode={currentEpisode} onNavigate={setTab} />}
          {tab === "episodes" && <EpisodesScreen currentEpisode={currentEpisode} onLoad={handleLoadEpisode} />}
        </div>
      </div>

      <div style={{ color: COLORS.textDim, fontSize: "11px", marginTop: "20px", textAlign: "center" }}>
        المحتوى المولد للاسترشاد والتعديل قبل النشر
      </div>
    </div>
  );
}
