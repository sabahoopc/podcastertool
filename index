<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>استوديو البودكاست</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Kufi+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{background:#0a0a0f;font-family:'Noto Kufi Arabic',sans-serif;direction:rtl;color:#e8e4d8;min-height:100vh;}
input,textarea,select{font-family:'Noto Kufi Arabic',sans-serif;}
textarea:focus,input:focus,select:focus{border-color:#c8a96e!important;outline:none;}
::-webkit-scrollbar{width:5px;}
::-webkit-scrollbar-track{background:#12121a;}
::-webkit-scrollbar-thumb{background:#2a2a3e;border-radius:3px;}
button{transition:opacity 0.15s;cursor:pointer;font-family:'Noto Kufi Arabic',sans-serif;}
button:hover:not(:disabled){opacity:0.82;}
@keyframes spin{to{transform:rotate(360deg);}}
</style>
</head>
<body>
<div id="root"></div>
<script>
const C={bg:"#0a0a0f",surface:"#12121a",card:"#1a1a26",border:"#2a2a3e",
  accent:"#c8a96e",accentDim:"#8a7048",accentGlow:"rgba(200,169,110,0.12)",
  text:"#e8e4d8",muted:"#7a7890",dim:"#4a4860",
  solo:"#4e9e8f",group:"#7e6db5",interview:"#c05c5c",ok:"#4e9e6f"};

const TYPES={
  solo:{label:"فردي",color:C.solo,icon:"◎",desc:"مذيع واحد يقدم المحتوى بمفرده"},
  group:{label:"جماعي",color:C.group,icon:"◈",desc:"أكثر من مذيع يناقشون موضوعاً"},
  interview:{label:"حواري",color:C.interview,icon:"◇",desc:"استضافة ضيف والتحاور معه"},
};
const DURS=["١٠–٢٠ دقيقة","٢٠–٤٠ دقيقة","٤٠–٦٠ دقيقة","٦٠–٩٠ دقيقة","أكثر من ٩٠ دقيقة"];
const FREQS=["يومي","أسبوعي","نصف شهري","شهري","غير منتظم"];
const SK="ps_style_v6",EK="ps_eps_v6",AK="ps_apikey";

const getApiKey=()=>localStorage.getItem(AK)||"";
const getStyle=()=>{try{return JSON.parse(localStorage.getItem(SK))||{};}catch{return{};}};
const getEps=()=>{try{return JSON.parse(localStorage.getItem(EK))||[];}catch{return[];}};
const saveEp=ep=>{
  const eps=getEps(),i=eps.findIndex(e=>e.id===ep.id);
  if(i>=0)eps[i]=ep;else eps.unshift(ep);
  localStorage.setItem(EK,JSON.stringify(eps));
};

const ai=async(sys,msg,max=3500)=>{
  const key=getApiKey();
  if(!key)throw new Error("أدخل الـ API Key أولاً");
  const r=await fetch("https://api.anthropic.com/v1/messages",{
    method:"POST",
    headers:{"Content-Type":"application/json","x-api-key":key,"anthropic-version":"2023-06-01"},
    body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:max,system:sys,messages:[{role:"user",content:msg}]}),
  });
  if(!r.ok){const e=await r.json().catch(()=>({}));throw new Error(e?.error?.message||"HTTP "+r.status);}
  const j=await r.json();
  return(j.content||[]).filter(b=>b.type==="text").map(b=>b.text).join("\n");
};

// ── DOM helpers ──
const el=(tag,attrs,...children)=>{
  const e=document.createElement(tag);
  if(attrs)for(const[k,v]of Object.entries(attrs)){
    if(k==="style")Object.assign(e.style,v);
    else if(k.startsWith("on"))e.addEventListener(k.slice(2).toLowerCase(),v);
    else e.setAttribute(k,v);
  }
  for(const c of children.flat(Infinity)){
    if(c==null||c===false)continue;
    e.appendChild(typeof c==="string"?document.createTextNode(c):c);
  }
  return e;
};

const IS={width:"100%",background:C.bg,border:`1px solid ${C.border}`,borderRadius:"6px",
  padding:"11px 13px",color:C.text,fontSize:"14px",direction:"rtl",
  lineHeight:"1.8",boxSizing:"border-box"};

const mkInp=(val,onChange,ph,multi=false,rows=4)=>{
  if(multi){
    const t=el("textarea",{placeholder:ph,rows,style:{...IS,resize:"vertical"}});
    t.value=val;t.addEventListener("input",e=>onChange(e.target.value));return t;
  }
  const i=el("input",{placeholder:ph,style:IS});
  i.value=val;i.addEventListener("input",e=>onChange(e.target.value));return i;
};

const mkSel=(val,onChange,options,ph)=>{
  const s=el("select",{style:{...IS,cursor:"pointer",appearance:"none",color:val?C.text:C.muted}},
    el("option",{value:"",disabled:"true"},ph),
    ...options.map(o=>el("option",{value:o},o)));
  s.value=val;s.addEventListener("change",e=>onChange(e.target.value));return s;
};

const mkBtn=(text,onClick,opts={})=>{
  const{fill,outline,small,full,disabled,color}=opts;
  return el("button",{onClick,disabled,style:{
    background:fill?(color||C.accent):"transparent",
    border:`1px solid ${fill?(color||C.accent):C.border}`,
    borderRadius:"6px",color:fill?"#0a0a0f":C.muted,
    fontWeight:"700",fontSize:small?"12px":"14px",
    padding:small?"6px 14px":"11px 22px",
    opacity:disabled?0.4:1,cursor:disabled?"not-allowed":"pointer",
    width:full?"100%":"auto",
  }},text);
};

const mkCard=(children,style={})=>
  el("div",{style:{background:C.card,border:`1px solid ${C.border}`,borderRadius:"12px",padding:"22px",...style}},...children);

const mkBadge=type=>{
  const t=TYPES[type];
  return el("span",{style:{fontSize:"12px",fontWeight:"700",padding:"2px 9px",borderRadius:"5px",
    background:`${t.color}20`,border:`1px solid ${t.color}`,color:t.color}},`${t.icon} ${t.label}`);
};

const mkLbl=text=>el("div",{style:{fontSize:"11px",letterSpacing:"0.13em",
  color:C.muted,textTransform:"uppercase",marginBottom:"8px"}},text);

const mkSpin=()=>el("div",{style:{textAlign:"center",padding:"36px 0"}},
  el("div",{style:{width:"32px",height:"32px",border:`3px solid ${C.border}`,
    borderTop:`3px solid ${C.accent}`,borderRadius:"50%",
    animation:"spin 0.8s linear infinite",margin:"0 auto 12px"}}),
  el("div",{style:{color:C.muted,fontSize:"13px"}},"جارٍ التوليد..."));

const mkOut=text=>el("div",{style:{background:C.bg,border:`1px solid ${C.border}`,
  borderRadius:"10px",padding:"18px",color:C.text,fontSize:"13px",lineHeight:"2",
  direction:"rtl",whiteSpace:"pre-wrap",maxHeight:"380px",overflowY:"auto"}},text);

const mkDots=(cur,tot)=>el("div",{style:{display:"flex",gap:"5px",justifyContent:"center",marginBottom:"28px"}},
  ...Array.from({length:tot},(_,i)=>el("div",{style:{
    width:i===cur?"22px":"7px",height:"7px",borderRadius:"4px",
    background:i===cur?C.accent:i<cur?C.accentDim:C.border,transition:"all 0.3s"}})));

const mkCopyBtn=(text)=>{
  const b=mkBtn("نسخ",()=>{
    navigator.clipboard.writeText(text);
    b.textContent="✓ تم النسخ";
    setTimeout(()=>{b.textContent="نسخ";},2000);
  },{outline:true,small:true});
  return b;
};

const mkNextBanner=(msg,sub,label,onClick,color=C.accent)=>
  el("div",{style:{marginTop:"14px",padding:"12px 16px",borderRadius:"10px",
    background:`${color}15`,border:`1px solid ${color}40`,
    display:"flex",alignItems:"center",justifyContent:"space-between"}},
    el("div",null,
      el("div",{style:{color,fontWeight:"700",fontSize:"13px",marginBottom:"2px"}},"✓ "+msg),
      el("div",{style:{color:C.muted,fontSize:"11px"}},sub)
    ),
    mkBtn(label+" ←",onClick,{fill:true,small:true,color})
  );

// ── NAV ──
const NAVTABS=[{id:"create",l:"إنشاء"},{id:"production",l:"الإنتاج"},{id:"marketing",l:"التسويق"},{id:"episodes",l:"حلقاتي"}];

// ── STATE ──
let S={
  tab:"create",showStyle:false,showApiKey:!getApiKey(),apiKeyInput:getApiKey(),
  hasStyle:false,episode:null,
  step:0,form:{name:"",type:"",duration:"",frequency:"",topic:"",hostCount:2},
  script:"",scriptBusy:false,
  prodFmt:"",prodResult:"",prodBusy:false,
  mktLink:"",mktTab:"description",mktOuts:{},mktBusy:"",mktDlDone:false,
  styleForm:{},styleSample:"",styleAnalyzing:false,
  eps:getEps(),
};
let RT=null;
const ss=patch=>{Object.assign(S,typeof patch==="function"?patch(S):patch);clearTimeout(RT);RT=setTimeout(render,16);};

// ── RENDER ──
function render(){
  const root=document.getElementById("root");
  root.innerHTML="";

  if(S.showApiKey){root.appendChild(mkApiKeyScreen());return;}
  if(S.showStyle){root.appendChild(mkStyleModal());}

  const app=el("div",{style:{minHeight:"100vh",display:"flex",flexDirection:"column",alignItems:"center",padding:"24px 14px"}});

  // header
  const hdr=el("div",{style:{width:"100%",maxWidth:"610px",marginBottom:"20px"}});
  const hdrTop=el("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"flex-start"}});

  const logo=el("div",null,
    el("div",{style:{display:"inline-flex",alignItems:"center",gap:"7px",
      background:C.surface,border:`1px solid ${C.border}`,borderRadius:"100px",
      padding:"4px 13px",marginBottom:"10px"}},
      el("div",{style:{width:"5px",height:"5px",borderRadius:"50%",background:C.accent,boxShadow:`0 0 6px ${C.accent}`}}),
      el("span",{style:{color:C.muted,fontSize:"10px",letterSpacing:"0.12em"}},"PODCAST STUDIO")
    ),
    el("div",{style:{fontSize:"21px",fontWeight:"700",color:C.text,marginBottom:"2px"}},"استوديو البودكاست"),
    el("div",{style:{color:C.muted,fontSize:"12px"}},"من الفكرة إلى النشر")
  );

  const btns=el("div",{style:{display:"flex",gap:"8px",alignItems:"flex-start"}},
    el("button",{onClick:()=>ss({showApiKey:true}),style:{
      background:C.surface,border:`1px solid ${C.border}`,borderRadius:"8px",
      padding:"7px 10px",color:C.muted,fontSize:"11px",fontWeight:"700"}},"🔑 API Key"),
    el("button",{onClick:()=>ss({showStyle:true,styleForm:getStyle()}),style:{
      background:S.hasStyle?C.accentGlow:C.surface,
      border:`1px solid ${S.hasStyle?C.accent:C.border}`,
      borderRadius:"10px",padding:"9px 13px",
      color:S.hasStyle?C.accent:C.muted,fontWeight:"700",fontSize:"11px",textAlign:"center"}},
      el("div",{style:{fontSize:"17px",marginBottom:"2px"}},"✦"),
      el("div",null,"أسلوبي"),
      el("div",{style:{fontSize:"9px",marginTop:"2px",opacity:"0.7"}},S.hasStyle?"مفعّل":"غير مُعدّ")
    )
  );

  hdrTop.append(logo,btns);hdr.appendChild(hdrTop);

  if(S.episode){
    hdr.appendChild(el("div",{style:{marginTop:"10px",background:C.surface,
      border:`1px solid ${C.border}`,borderRadius:"8px",padding:"9px 13px",
      display:"flex",alignItems:"center",gap:"8px"}},
      el("div",{style:{width:"6px",height:"6px",borderRadius:"50%",background:C.ok,flexShrink:"0"}}),
      el("span",{style:{color:C.muted,fontSize:"11px"}},"الحلقة الحالية:"),
      el("span",{style:{fontWeight:"700",fontSize:"12px",color:C.text}},S.episode.name),
      mkBadge(S.episode.type)
    ));
  }

  // nav
  const nav=el("div",{style:{display:"flex",gap:"3px",background:C.surface,
    border:`1px solid ${C.border}`,borderRadius:"10px",padding:"4px",marginBottom:"22px"}},
    ...NAVTABS.map(t=>el("button",{onClick:()=>ss({tab:t.id}),style:{
      flex:"1",background:S.tab===t.id?C.accent:"transparent",border:"none",borderRadius:"7px",
      padding:"9px 4px",color:S.tab===t.id?"#0a0a0f":C.muted,fontWeight:"700",fontSize:"12px"}},t.l))
  );

  const main=el("div",{style:{width:"100%",maxWidth:"610px"}},
    el("div",{style:{background:C.surface,border:`1px solid ${C.border}`,borderRadius:"14px",padding:"22px"}},
      nav,
      S.tab==="create"?mkCreateScreen():
      S.tab==="production"?mkProductionScreen():
      S.tab==="marketing"?mkMarketingScreen():
      mkEpisodesScreen()
    )
  );

  const footer=el("div",{style:{color:C.dim,fontSize:"10px",marginTop:"18px",textAlign:"center"}},
    "المحتوى المولد للاسترشاد والتعديل قبل النشر");

  app.append(hdr,main,footer);
  root.appendChild(app);
}

// ── API KEY SCREEN ──
function mkApiKeyScreen(){
  const wrap=el("div",{style:{minHeight:"100vh",display:"flex",alignItems:"center",
    justifyContent:"center",padding:"16px",background:C.bg}});
  const box=el("div",{style:{background:C.surface,border:`1px solid ${C.border}`,
    borderRadius:"14px",width:"100%",maxWidth:"460px",padding:"32px"}});

  const inp=mkInp(S.apiKeyInput,v=>ss({apiKeyInput:v}),"sk-ant-api03-...");
  inp.style.fontFamily="monospace";inp.style.fontSize="13px";

  box.append(
    el("div",{style:{fontSize:"22px",fontWeight:"700",color:C.text,marginBottom:"8px"}},"🔑 API Key"),
    el("div",{style:{color:C.muted,fontSize:"13px",marginBottom:"20px",lineHeight:"1.8"}},
      "للحصول على API Key:",el("br"),
      "١. اذهب إلى ",
      el("a",{href:"https://console.anthropic.com/",target:"_blank",
        style:{color:C.accent}},"console.anthropic.com"),
      el("br"),"٢. API Keys ← Create Key",el("br"),"٣. انسخ الـ Key والصقه هنا"
    ),
    mkLbl("الـ API Key"),
    inp,
    el("div",{style:{color:C.dim,fontSize:"11px",marginTop:"8px",marginBottom:"20px"}},
      "يُحفظ في متصفحك فقط — لا يُرسل لأي جهة غير Anthropic مباشرة"),
    mkBtn("حفظ والبدء",()=>{
      const k=S.apiKeyInput.trim();
      if(!k)return;
      localStorage.setItem(AK,k);
      ss({showApiKey:false});
    },{fill:true,full:true,disabled:!S.apiKeyInput.trim()})
  );
  wrap.appendChild(box);return wrap;
}

// ── STYLE MODAL ──
function mkStyleModal(){
  const overlay=el("div",{style:{position:"fixed",inset:"0",background:"rgba(0,0,0,0.78)",
    display:"flex",alignItems:"center",justifyContent:"center",zIndex:"9999",padding:"16px"}});
  const box=el("div",{style:{background:C.surface,border:`1px solid ${C.border}`,
    borderRadius:"14px",width:"100%",maxWidth:"540px",maxHeight:"90vh",overflowY:"auto",padding:"26px"}});

  const sampleInp=mkInp(S.styleSample,v=>ss({styleSample:v}),"الصق مقطعاً من حلقة سابقة...",true,3);

  const analyzeBtn=mkBtn(S.styleAnalyzing?"جارٍ التحليل...":"تحليل وملء تلقائي",async()=>{
    if(!S.styleSample.trim()||S.styleAnalyzing)return;
    ss({styleAnalyzing:true});
    try{
      const raw=await ai("أنت محلل أسلوب. ردودك JSON فقط بدون أي نص إضافي.",
        `حلّل هذا السكريبت وأجب بـ JSON فقط:\n{"tone":"","opening":"","language":"","structure":"","closing":"","distinctive":""}\n\nالسكريبت: ${S.styleSample}`,600);
      const parsed=JSON.parse(raw.trim());
      ss({styleForm:{...S.styleForm,...parsed},styleAnalyzing:false});
    }catch{ss({styleAnalyzing:false});}
  },{fill:true,small:true,color:C.accent,disabled:S.styleAnalyzing});

  const FIELDS=[
    {k:"tone",l:"النبرة العامة",ph:"دافئ، تحليلي، حماسي..."},
    {k:"opening",l:"طريقة الافتتاح",ph:"سؤال تشويقي، قصة..."},
    {k:"language",l:"نوع اللغة",ph:"فصحى / خليجية / مزيج..."},
    {k:"closing",l:"طريقة الختام",ph:"سؤال للمتابعين، توصية..."},
    {k:"distinctive",l:"بصمتك المميزة",ph:"ما يجعل أسلوبك مختلفاً..."},
  ];

  const fields=el("div",{style:{display:"grid",gap:"14px"}},
    ...FIELDS.map(f=>el("div",null,
      mkLbl(f.l),
      mkInp(S.styleForm[f.k]||"",v=>ss({styleForm:{...S.styleForm,[f.k]:v}}),f.ph)
    )),
    el("div",null,mkLbl("بناء المحتوى وتدفقه"),
      mkInp(S.styleForm.structure||"",v=>ss({styleForm:{...S.styleForm,structure:v}}),"كيف تنظم أفكارك...",true,3))
  );

  box.append(
    el("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"18px"}},
      el("div",null,
        el("div",{style:{fontSize:"17px",fontWeight:"700",color:C.text}},"✦ ملف أسلوبي"),
        el("div",{style:{color:C.muted,fontSize:"12px",marginTop:"3px"}},"يُطبَّق تلقائياً في كل سكريبت")
      ),
      el("button",{onClick:()=>ss({showStyle:false}),
        style:{background:"none",border:"none",color:C.muted,fontSize:"20px"}},"✕")
    ),
    mkCard([
      el("div",{style:{fontSize:"12px",color:C.accent,fontWeight:"700",marginBottom:"8px"}},"استخراج تلقائي من سكريبت سابق"),
      sampleInp,
      el("div",{style:{marginTop:"10px"}},analyzeBtn)
    ],{marginBottom:"18px",borderColor:`${C.accent}50`}),
    fields,
    el("div",{style:{display:"flex",justifyContent:"space-between",marginTop:"22px"}},
      mkBtn("إلغاء",()=>ss({showStyle:false}),{outline:true}),
      mkBtn("حفظ الملف",()=>{
        localStorage.setItem(SK,JSON.stringify({...S.styleForm,ts:Date.now()}));
        const sf=S.styleForm;
        ss({showStyle:false,hasStyle:!!(sf.tone||sf.opening)});
      },{fill:true,disabled:!(S.styleForm.tone||S.styleForm.opening)})
    )
  );
  overlay.appendChild(box);return overlay;
}

// ── CREATE SCREEN ──
function mkCreateScreen(){
  const wrap=el("div",null,mkDots(S.step,3));
  const d=S.form;
  const cfg=d.type?TYPES[d.type]:{color:C.accent};

  const styleBlock=()=>{
    const st=getStyle();if(!Object.keys(st).length)return"";
    const lines=[st.tone&&"النبرة: "+st.tone,st.opening&&"الافتتاح: "+st.opening,
      st.language&&"اللغة: "+st.language,st.structure&&"البناء: "+st.structure,
      st.closing&&"الختام: "+st.closing,st.distinctive&&"البصمة: "+st.distinctive].filter(Boolean);
    return lines.length?"\n\n--- أسلوب المذيع (التزم به) ---\n"+lines.join("\n")+"\n--------------------------------":"";
  };

  const buildPrompt=()=>{
    const h=`البودكاست: "${d.name}" | النوع: ${TYPES[d.type].label} | المدة: ${d.duration} | النشر: ${d.frequency}${styleBlock()}\n\n`;
    if(d.type==="solo")return h+`الموضوع: ${d.topic}\n\nاكتب سكريبت كامل جاهز للتسجيل مباشرةً:\n١- مقدمة جذابة كاملة\n٢- عرض الموضوع بتفصيل مع انتقالات طبيعية\n٣- تعمق في كل نقطة مع أمثلة وقصص\n٤- خاتمة قوية مع call to action\nضع [توقف] عند الانتقالات. الطول يتناسب مع ${d.duration}.`;
    if(d.type==="group"){
      const n=d.hostCount||2;
      const names=["م١","م٢","م٣","م٤","م٥"].slice(0,n).join("، ");
      return h+`الموضوع: ${d.topic}\nعدد المذيعين: ${n}\n\nاكتب سكريبت حوار جماعي كامل موزع على (${names}). كل جملة مكتوبة كاملاً. يشمل مقدمة، حوار متدفق مع نقاط توافق وخلاف، وخاتمة مشتركة. الطول يتناسب مع ${d.duration}.`;
    }
    return h+`الضيف/الموضوع: ${d.topic}\n\nاكتب قائمة أسئلة احترافية:\n١- ٣ أسئلة تمهيدية\n٢- ٦–٨ أسئلة جوهرية متدرجة\n٣- ٣ أسئلة استفزازية\n٤- سؤال ختامي مميز\nلكل سؤال: السؤال كاملاً + هدفه + أسئلة متابعة.`;
  };

  // STEP 0
  if(S.step===0){
    wrap.append(
      el("div",{style:{marginBottom:"22px"}},
        el("div",{style:{fontSize:"19px",fontWeight:"700",color:C.text,marginBottom:"4px"}},"◎ هوية البودكاست"),
        el("div",{style:{color:C.muted,fontSize:"13px"}},"ابدأ بتحديد اسم البودكاست وطبيعته")
      ),
      el("div",{style:{marginBottom:"16px"}},mkLbl("اسم البودكاست"),
        mkInp(d.name,v=>ss({form:{...d,name:v}}),"مثال: بودكاست مدى، صوت العقل...")),
      mkLbl("نوع البودكاست"),
      el("div",{style:{display:"grid",gridTemplateColumns:"1fr 1fr 1fr",gap:"10px",marginBottom:"26px"}},
        ...Object.entries(TYPES).map(([k,t])=>{
          const sel=d.type===k;
          return el("div",{onClick:()=>ss({form:{...d,type:k}}),style:{
            border:`2px solid ${sel?t.color:C.border}`,borderRadius:"10px",padding:"14px 10px",
            cursor:"pointer",background:sel?`${t.color}12`:C.bg,transition:"all 0.2s",textAlign:"center"}},
            el("div",{style:{fontSize:"22px",marginBottom:"5px"}},t.icon),
            el("div",{style:{fontWeight:"700",fontSize:"13px",color:sel?t.color:C.text,marginBottom:"3px"}},t.label),
            el("div",{style:{fontSize:"11px",color:C.muted,lineHeight:"1.5"}},t.desc)
          );
        })
      ),
      el("div",{style:{textAlign:"left"}},
        mkBtn("التالي ←",()=>ss({step:1}),{fill:true,disabled:!d.name||!d.type}))
    );
  }

  // STEP 1
  if(S.step===1){
    wrap.append(
      el("div",{style:{display:"flex",alignItems:"center",gap:"10px",marginBottom:"20px"}},
        mkBadge(d.type),el("span",{style:{fontWeight:"700",color:C.text}},d.name)),
      el("div",{style:{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"12px",marginBottom:"14px"}},
        el("div",null,mkLbl("مدة الحلقة"),mkSel(d.duration,v=>ss({form:{...d,duration:v}}),DURS,"اختر المدة")),
        el("div",null,mkLbl("تكرار النشر"),mkSel(d.frequency,v=>ss({form:{...d,frequency:v}}),FREQS,"كم مرة؟"))
      )
    );
    if(d.type==="group"){
      wrap.append(el("div",{style:{marginBottom:"14px"}},mkLbl("عدد المذيعين"),
        el("div",{style:{display:"flex",gap:"8px"}},
          ...[2,3,4,5].map(n=>el("div",{onClick:()=>ss({form:{...d,hostCount:n}}),style:{
            border:`2px solid ${d.hostCount===n?cfg.color:C.border}`,borderRadius:"8px",
            padding:"8px 14px",cursor:"pointer",fontWeight:"700",
            color:d.hostCount===n?cfg.color:C.muted,
            background:d.hostCount===n?`${cfg.color}15`:"transparent"}},""+n))
        )
      ));
    }
    wrap.append(
      el("div",{style:{marginBottom:"20px"}},
        mkLbl(d.type==="solo"?"الموضوع أو الفكرة الكاملة":d.type==="group"?"موضوع النقاش وأبرز المحاور":"موضوع الحلقة وتفاصيل الضيف"),
        mkInp(d.topic,v=>ss({form:{...d,topic:v}}),
          d.type==="solo"?"اكتب الفكرة بشكل موسع...":d.type==="group"?"ما الموضوع الذي ستناقشونه؟":"من الضيف؟ وما المحور؟",
          true,5)
      ),
      el("div",{style:{display:"flex",justifyContent:"space-between"}},
        mkBtn("← رجوع",()=>ss({step:0}),{outline:true}),
        mkBtn("توليد السكريبت ←",()=>ss({step:2}),{fill:true,disabled:!d.duration||!d.frequency||!d.topic})
      )
    );
  }

  // STEP 2
  if(S.step===2){
    wrap.append(
      el("div",{style:{display:"flex",alignItems:"center",gap:"10px",marginBottom:"5px"}},
        mkBadge(d.type),el("span",{style:{fontWeight:"700",color:C.text,fontSize:"15px"}},d.name)),
      el("div",{style:{color:C.muted,fontSize:"12px",marginBottom:"18px"}},d.duration+" · "+d.frequency)
    );

    if(!S.script&&!S.scriptBusy){
      wrap.append(mkCard([
        el("div",{style:{fontSize:"30px",marginBottom:"10px",textAlign:"center"}},
          d.type==="solo"?"✦":d.type==="group"?"⬡":"◈"),
        el("div",{style:{fontWeight:"700",fontSize:"14px",color:C.text,marginBottom:"5px",textAlign:"center"}},
          "جاهز لتوليد "+(d.type==="solo"?"السكريبت":d.type==="group"?"سكريبت الحوار":"أسئلة الحلقة")),
        el("div",{style:{color:C.muted,fontSize:"12px",marginBottom:"22px",textAlign:"center"}},
          Object.keys(getStyle()).length?"سيتم الكتابة بأسلوبك الشخصي":"سيتم التوليد بناءً على معلوماتك"),
        el("div",{style:{textAlign:"center"}},
          mkBtn("توليد المحتوى",async()=>{
            ss({scriptBusy:true,script:""});
            try{
              const text=await ai("أنت خبير بودكاست عربي. تكتب سكريبتات كاملة جاهزة للتسجيل. إذا وُجد ملف أسلوب، التزم به في كل جملة. ردودك بالعربية.",buildPrompt());
              const ep={id:Date.now()+"",name:d.name,type:d.type,duration:d.duration,
                frequency:d.frequency,topic:d.topic,script:text,hostCount:d.hostCount,
                createdAt:new Date().toISOString()};
              saveEp(ep);
              ss({script:text,scriptBusy:false,episode:ep,eps:getEps()});
            }catch(e){ss({script:"خطأ: "+e.message,scriptBusy:false});}
          },{fill:true,color:cfg.color}))
      ]));
    }

    if(S.scriptBusy)wrap.append(mkSpin());

    if(S.script&&!S.scriptBusy){
      wrap.append(
        el("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"8px"}},
          mkLbl("السكريبت المولّد"),mkCopyBtn(S.script)),
        mkOut(S.script),
        el("div",{style:{display:"flex",gap:"8px",marginTop:"10px",justifyContent:"flex-end"}},
          mkBtn("إعادة التوليد",async()=>{
            ss({scriptBusy:true,script:""});
            try{
              const text=await ai("أنت خبير بودكاست عربي. تكتب سكريبتات كاملة جاهزة للتسجيل. إذا وُجد ملف أسلوب، التزم به. ردودك بالعربية.",buildPrompt());
              ss({script:text,scriptBusy:false});
            }catch(e){ss({script:"خطأ: "+e.message,scriptBusy:false});}
          },{outline:true,small:true})
        ),
        mkNextBanner("السكريبت جاهز","الخطوة التالية: نصائح الإنتاج","الإنتاج",()=>ss({tab:"production"}))
      );
    }

    wrap.append(el("div",{style:{display:"flex",justifyContent:"space-between",marginTop:"14px"}},
      mkBtn("← رجوع",()=>ss({step:1}),{outline:true}),
      mkBtn("حلقة جديدة",()=>ss({step:0,form:{name:"",type:"",duration:"",frequency:"",topic:"",hostCount:2},script:""}),{outline:true})
    ));
  }
  return wrap;
}

// ── PRODUCTION ──
function mkProductionScreen(){
  const wrap=el("div",null,
    el("div",{style:{marginBottom:"22px"}},
      el("div",{style:{fontSize:"19px",fontWeight:"700",color:C.text,marginBottom:"4px"}},"◉ نصائح الإنتاج"),
      el("div",{style:{color:C.muted,fontSize:"13px"}},"اختر نوع الاستوديو للحصول على توصيات مخصصة")
    )
  );
  if(!S.episode)wrap.append(mkCard([el("div",{style:{color:C.muted,fontSize:"14px",textAlign:"center"}},'أنشئ حلقة أولاً من صفحة "إنشاء"')],{marginBottom:"16px"}));

  wrap.append(
    mkLbl("نوع الاستوديو"),
    el("div",{style:{display:"grid",gridTemplateColumns:"1fr 1fr",gap:"10px",marginBottom:"18px"}},
      ...[{id:"audio",icon:"🎙️",label:"صوتي فقط",desc:"ميكروفون وتسجيل صوتي"},
          {id:"video",icon:"🎥",label:"مصوَّر",desc:"كاميرا وإضاءة ومونتاج"}].map(f=>
        el("div",{onClick:()=>ss({prodFmt:f.id}),style:{
          border:`2px solid ${S.prodFmt===f.id?C.accent:C.border}`,borderRadius:"10px",padding:"18px",
          cursor:"pointer",background:S.prodFmt===f.id?C.accentGlow:C.bg,transition:"all 0.2s",textAlign:"center"}},
          el("div",{style:{fontSize:"26px",marginBottom:"7px"}},f.icon),
          el("div",{style:{fontWeight:"700",fontSize:"14px",marginBottom:"3px",
            color:S.prodFmt===f.id?C.accent:C.text}},f.label),
          el("div",{style:{fontSize:"12px",color:C.muted}},f.desc)
        )
      )
    ),
    mkBtn(S.prodBusy?"جارٍ التوليد...":"توليد نصائح الإنتاج",async()=>{
      if(!S.prodFmt||S.prodBusy)return;
      ss({prodBusy:true,prodResult:""});
      const ep=S.episode,t=ep?.type||"solo",isA=S.prodFmt==="audio";
      const prompt=isA
        ?`البودكاست: ${ep?.name||"—"} | النوع: ${TYPES[t]?.label} | الموضوع: ${ep?.topic||"—"}\n\nأعطِ نصائح مفصّلة للتسجيل الصوتي:\n\n🎙️ وضع الميكروفون: المسافة المثالية بالسنتيمترات والزاوية. الفرق بين الديناميكي والكوندنسر.\n\n📍 المكان والمعالجة الصوتية: خصائص الغرفة المثالية. طرق عزل الصوت منخفضة التكلفة. ما يجب تجنبه.\n\n🎚️ التحرير الصوتي: برامج موصى بها. إعدادات EQ والضغط. إزالة الضوضاء والصمت.\n\n🎵 الموسيقى المرافقة: نوع الموسيقى المناسب لهذا البودكاست تحديداً. مواقع مجانية. توقيت الاستخدام مع أحجام صوت مقترحة.`
        :`البودكاست: ${ep?.name||"—"} | النوع: ${TYPES[t]?.label} | الموضوع: ${ep?.topic||"—"}\n\nأعطِ نصائح مفصّلة لتصوير هذا البودكاست (${t==="solo"?"مذيع فردي":t==="group"?(ep?.hostCount||2)+" مذيعين":"مذيع وضيف"}):\n\n📷 الكاميرات: عدد الكاميرات وزوايا كل منها. المسافة البؤرية. إعدادات التعرض.\n\n💡 الإضاءة: مخطط Key/Fill/Back. درجات الحرارة بـ Kelvin. بدائل منخفضة التكلفة.\n\n🎨 الديكور والخلفية: اقتراحات تتناسب مع موضوع البودكاست. ما يجب تجنبه.\n\n✂️ المونتاج: برامج مقترحة. إعدادات التصدير لكل منصة.\n\n🎵 الموسيقى المرافقة: نوع الموسيقى المناسب. توقيت استخدامها.`;
      try{
        const text=await ai("أنت خبير إنتاج بودكاست عربي. أجب بالعربية بشكل مفصّل وعملي.",prompt);
        ss({prodResult:text,prodBusy:false});
      }catch(e){ss({prodResult:"خطأ: "+e.message,prodBusy:false});}
    },{fill:true,full:true,disabled:!S.prodFmt||S.prodBusy})
  );

  if(S.prodBusy)wrap.append(mkSpin());
  if(S.prodResult&&!S.prodBusy){
    wrap.append(el("div",{style:{marginTop:"16px"}},
      el("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"8px"}},
        mkLbl("توصيات الإنتاج"),mkCopyBtn(S.prodResult)),
      mkOut(S.prodResult),
      mkNextBanner("نصائح الإنتاج جاهزة","الخطوة التالية: التسويق والنشر","التسويق",()=>ss({tab:"marketing"}))
    ));
  }
  return wrap;
}

// ── MARKETING ──
function mkMarketingScreen(){
  const MTABS=[{id:"description",l:"وصف الحلقة"},{id:"social",l:"السوشيال"},
    {id:"email",l:"نشرة بريدية"},{id:"titles",l:"عناوين بديلة"}];

  const genMkt=async(t)=>{
    if(!S.episode)return;
    ss({mktBusy:t});
    const ep=S.episode;
    const base=`البودكاست: "${ep.name}" | النوع: ${TYPES[ep.type]?.label}\nالموضوع: ${ep.topic}\n${S.mktLink?"رابط الحلقة: "+S.mktLink:""}\n\n`;
    const prompts={
      description:base+"اكتب وصفاً احترافياً للحلقة لـ Spotify وAnghami وApple Podcasts:\n- ٣–٥ فقرات\n- جملة تشويقية قوية\n- ما سيستفيده المستمع\n- كلمات مفتاحية\n- دعوة للاشتراك",
      social:base+"اكتب محتوى السوشيال:\n١. تغريدة X (أقل من 280 حرف)\n٢. منشور انستقرام مع هاشتاقات\n٣. منشور لينكدإن\n٤. اقتباس للتصميم الجرافيكي",
      email:base+"اكتب نشرة بريدية:\n- سطر موضوع جذاب\n- مقدمة ترحيب\n- ملخص ٣ نقاط\n- أبرز اقتباس\n- رابط للاستماع\n- خاتمة ودية",
      titles:base+"اقترح ١٠ عناوين بديلة:\n- ٣ تثير الفضول\n- ٣ تركز على الفائدة\n- ٢ تستخدم الأرقام\n- ٢ قصيرة ومباشرة\nلكل عنوان: سبب اختياره.",
    };
    try{
      const text=await ai("أنت خبير تسويق بودكاست عربي. ردودك بالعربية.",prompts[t]);
      ss({mktOuts:{...S.mktOuts,[t]:text},mktBusy:""});
    }catch(e){ss({mktOuts:{...S.mktOuts,[t]:"خطأ: "+e.message},mktBusy:""});}
  };

  const wrap=el("div",null,
    el("div",{style:{marginBottom:"20px"}},
      el("div",{style:{fontSize:"19px",fontWeight:"700",color:C.text,marginBottom:"4px"}},"◐ التسويق والنشر"),
      el("div",{style:{color:C.muted,fontSize:"13px"}},"توليد محتوى تسويقي جاهز لكل المنصات")
    ),
    el("div",{style:{marginBottom:"16px"}},mkLbl("رابط الحلقة (اختياري)"),
      mkInp(S.mktLink,v=>ss({mktLink:v}),"https://open.spotify.com/episode/...")),
  );

  if(!S.episode)wrap.append(mkCard([el("div",{style:{color:C.muted,fontSize:"14px",textAlign:"center"}},'أنشئ حلقة أولاً من صفحة "إنشاء"')],{marginBottom:"16px"}));

  wrap.append(
    el("div",{style:{display:"flex",gap:"3px",background:C.bg,border:`1px solid ${C.border}`,
      borderRadius:"8px",padding:"3px",marginBottom:"16px"}},
      ...MTABS.map(t=>el("button",{onClick:()=>ss({mktTab:t.id}),style:{
        flex:"1",background:S.mktTab===t.id?C.surface:"transparent",
        border:S.mktTab===t.id?`1px solid ${C.border}`:"1px solid transparent",
        borderRadius:"6px",padding:"7px 4px",color:S.mktTab===t.id?C.text:C.muted,
        fontWeight:"600",fontSize:"11px",whiteSpace:"nowrap"}},t.l))
    ),
    mkBtn(S.mktBusy===S.mktTab?"جارٍ التوليد...":"توليد "+MTABS.find(t=>t.id===S.mktTab)?.l,
      ()=>genMkt(S.mktTab),{fill:true,full:true,disabled:!S.episode||!!S.mktBusy})
  );

  if(S.mktBusy===S.mktTab)wrap.append(mkSpin());
  if(S.mktOuts[S.mktTab]&&S.mktBusy!==S.mktTab){
    wrap.append(el("div",{style:{marginTop:"14px"}},
      el("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:"8px"}},
        mkLbl(MTABS.find(t=>t.id===S.mktTab)?.l),mkCopyBtn(S.mktOuts[S.mktTab])),
      mkOut(S.mktOuts[S.mktTab])
    ));
  }

  wrap.append(el("div",{style:{marginTop:"20px",borderTop:`1px solid ${C.border}`,paddingTop:"18px"}},
    el("div",{style:{fontSize:"12px",color:C.muted,marginBottom:"10px"}},"حفظ كل محتوى الحلقة في ملف واحد"),
    mkBtn("⬇ تنزيل ملف الحلقة",()=>{
      if(!S.episode)return;
      const ep=S.episode;
      const content=["# "+ep.name,"**الموضوع:** "+ep.topic,
        "**النوع:** "+TYPES[ep.type]?.label,"**المدة:** "+ep.duration,
        S.mktLink?"**رابط:** "+S.mktLink:"","---","","## السكريبت",ep.script||"—","",
        S.mktOuts.description?"## الوصف\n"+S.mktOuts.description:"",
        S.mktOuts.social?"## السوشيال\n"+S.mktOuts.social:"",
        S.mktOuts.email?"## النشرة\n"+S.mktOuts.email:"",
        S.mktOuts.titles?"## العناوين البديلة\n"+S.mktOuts.titles:"",
      ].filter(Boolean).join("\n");
      const blob=new Blob([content],{type:"text/plain;charset=utf-8"});
      const url=URL.createObjectURL(blob);
      const a=document.createElement("a");
      a.href=url;a.download=(ep.name||"podcast")+".md";a.click();
      URL.revokeObjectURL(url);
      ss({mktDlDone:true});
    },{outline:true,full:true,disabled:!S.episode}),
    S.mktDlDone?mkNextBanner("الحلقة مكتملة","شاهد جميع حلقاتك المحفوظة","حلقاتي",()=>ss({tab:"episodes"}),C.ok):null
  ));
  return wrap;
}

// ── EPISODES ──
function mkEpisodesScreen(){
  const eps=S.eps;
  const wrap=el("div",null,
    el("div",{style:{marginBottom:"20px"}},
      el("div",{style:{fontSize:"19px",fontWeight:"700",color:C.text,marginBottom:"4px"}},"▦ حلقاتي"),
      el("div",{style:{color:C.muted,fontSize:"13px"}},eps.length+" حلقة محفوظة")
    )
  );
  if(!eps.length)return wrap.appendChild(mkCard([
    el("div",{style:{fontSize:"28px",marginBottom:"10px",textAlign:"center"}},"◌"),
    el("div",{style:{color:C.muted,fontSize:"14px",textAlign:"center"}},'لا توجد حلقات — ابدأ من صفحة "إنشاء"')
  ],{padding:"40px"})),wrap;

  wrap.append(el("div",{style:{display:"grid",gap:"10px"}},
    ...eps.map(ep=>mkCard([
      el("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:"7px"}},
        el("div",null,
          el("div",{style:{fontWeight:"700",color:C.text,fontSize:"14px",marginBottom:"4px"}},ep.name),
          el("div",{style:{display:"flex",gap:"7px",alignItems:"center"}},mkBadge(ep.type),
            el("span",{style:{color:C.muted,fontSize:"11px"}},ep.duration))
        ),
        el("button",{onClick:()=>{
          const u=eps.filter(e=>e.id!==ep.id);
          localStorage.setItem(EK,JSON.stringify(u));ss({eps:u});
        },style:{background:"none",border:"none",color:C.dim,fontSize:"15px"}},"✕")
      ),
      el("div",{style:{color:C.muted,fontSize:"12px",marginBottom:"9px",lineHeight:"1.5"}},
        (ep.topic||"").slice(0,100)+((ep.topic||"").length>100?"...":"")),
      el("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"center"}},
        el("span",{style:{fontSize:"11px",color:C.dim}},new Date(ep.createdAt).toLocaleDateString("ar-SA")),
        mkBtn("تحميل",()=>ss({episode:ep,tab:"create",step:2,
          script:ep.script,form:{name:ep.name,type:ep.type,duration:ep.duration,
          frequency:ep.frequency,topic:ep.topic,hostCount:ep.hostCount||2}}),{fill:true,small:true})
      )
    ],{padding:"16px"}))
  ));
  return wrap;
}

render();
</script>
