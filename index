              fontFamily: "'Noto Kufi Arabic', sans-serif", fontSize: "12px", fontWeight: "700", textAlign: "center",
            }}>
              <div style={{ fontSize: "18px", marginBottom: "3px" }}>📚</div>
              <div>الأرشيف</div>
              {epCount > 0 && <div style={{ fontSize: "10px", color: C.accent, marginTop: "2px" }}>{epCount}</div>}
            </button>

            {/* Style */}
            <button onClick={() => setShowStyle(true)} style={{
              background: hasStyle ? C.accentGlow : C.surface,
              border: `1px solid ${hasStyle ? C.accent : C.border}`,
              borderRadius: "10px", padding: "10px 14px", cursor: "pointer",
              color: hasStyle ? C.accent : C.textMuted,
              fontFamily: "'Noto Kufi Arabic', sans-serif", fontSize: "12px", fontWeight: "700", textAlign: "center",
            }}>
              <div style={{ fontSize: "18px", marginBottom: "3px" }}>✦</div>
              <div>أسلوبي</div>
              <div style={{ fontSize: "10px", marginTop: "2px", opacity: 0.7 }}>{hasStyle ? "مفعّل" : "غير مُعدّ"}</div>
            </button>
          </div>
        </div>
      </div>

      {/* Main Card */}
      <div style={{ width: "100%", maxWidth: "620px" }}>
        <div style={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: "16px", padding: "32px" }}>
          <StepDots current={step} total={STEPS} />
          {step === 0 && <Step1 data={data} setData={setData} onNext={() => setStep(1)} />}
          {step === 1 && <Step2 data={data} setData={setData} onNext={() => setStep(2)} onBack={() => setStep(0)} />}
          {step === 2 && <Step3 data={data} onNext={s => { setScript(s); setStep(3); }} onBack={() => setStep(1)} />}
          {step === 3 && <Step4 data={data} script={script} onNext={() => setStep(4)} onBack={() => setStep(2)} />}
          {step === 4 && <Step5 data={data} script={script} onNext={() => setStep(5)} onBack={() => setStep(3)} />}
          {step === 5 && <Step6 data={data} script={script} onSave={() => { checkStorage(); reset(); }} onReset={reset} onBack={() => setStep(4)} />}
        </div>
      </div>

      <div style={{ color: C.textDim, fontSize: "10px", marginTop: "20px" }}>
        المحتوى المولد للاسترشاد والتعديل — راجع دائماً قبل التسجيل
      </div>
    </div>
  );
}
