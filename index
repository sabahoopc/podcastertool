// ─── Step 6: Publish ──────────────────────────────────────────────────────────
function Step6({ data, script, onSave, onReset, onBack }) {
  const [link, setLink] = useState("");
  const [notes, setNotes] = useState("");
  const [saved, setSaved] = useState(false);

  const save = () => {
    try {
      const eps = JSON.parse(localStorage.getItem(EPS_KEY)) || [];
      eps.unshift({
        id: Date.now(),
        podcast: data.name,
        type: data.type,
        topic: data.topic,
        duration: data.duration,
        frequency: data.frequency,
        studioType: data.studioType,
        script: script,
        link,
        notes,
        date: new Date().toISOString(),
      });
      localStorage.setItem(EPS_KEY, JSON.stringify(eps.slice(0, 50)));
      setSaved(true);
      setTimeout(() => onSave(), 1200);
    } catch (e) { alert("خطأ في الحفظ"); }
  };

  return (
    <div>
      <div style={{ marginBottom: "20px" }}>
        <div style={{ fontSize: "18px", fontWeight: "700", color: C.text, marginBottom: "4px" }}>🚀 النشر والحفظ</div>
        <div style={{ color: C.textMuted, fontSize: "12px" }}>أضف رابط الحلقة واحفظها في أرشيفك</div>
      </div>

      <Card style={{ marginBottom: "16px" }}>
        <div style={{ display: "flex", alignItems: "center", gap: "10px", marginBottom: "16px" }}>
          <TypeBadge type={data.type} />
          <span style={{ color: C.text, fontWeight: "600" }}>{data.name}</span>
        </div>
        <div style={{ color: C.textMuted, fontSize: "12px", display: "flex", gap: "16px" }}>
          <span>{data.duration}</span>
          <span>{data.frequency}</span>
          <span>{data.studioType === "video" ? "🎬 مصوّر" : "🎙 صوتي"}</span>
        </div>
      </Card>

      <div style={{ marginBottom: "18px" }}>
        <Lbl hint="(اختياري)">رابط الحلقة المنشورة</Lbl>
        <Inp value={link} onChange={setLink} placeholder="https://open.spotify.com/episode/..." />
      </div>

      <div style={{ marginBottom: "24px" }}>
        <Lbl hint="(اختياري)">ملاحظات شخصية</Lbl>
        <Inp value={notes} onChange={setNotes} placeholder="ملاحظات عن الحلقة، أشياء للتحسين، ردود الفعل..." multiline rows={3} />
      </div>

      <Btn onClick={save} full>{saved ? "✓ تم الحفظ في الأرشيف" : "💾 حفظ الحلقة في الأرشيف"}</Btn>

      <div style={{ display: "flex", justifyContent: "space-between", marginTop: "20px" }}>
        <Btn variant="outline" onClick={onBack}>← رجوع</Btn>
        <Btn variant="outline" onClick={onReset}>بودكاست جديد</Btn>
      </div>
    </div>
  );
}

// ─── Episodes Archive ─────────────────────────────────────────────────────────
function EpisodesPage({ onClose }) {
  const [eps, setEps] = useState(() => { try { return JSON.parse(localStorage.getItem(EPS_KEY)) || []; } catch { return []; } });
  const [selected, setSelected] = useState(null);

  const del = (id) => {
    const updated = eps.filter(e => e.id !== id);
    localStorage.setItem(EPS_KEY, JSON.stringify(updated));
    setEps(updated);
    if (selected?.id === id) setSelected(null);
  };

  return (
    <div style={{ position: "fixed", inset: 0, background: "#0a0a0ff2", backdropFilter: "blur(4px)", display: "flex", alignItems: "center", justifyContent: "center", zIndex: 200, padding: "16px" }}>
      <div style={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: "16px", width: "100%", maxWidth: "680px", maxHeight: "92vh", display: "flex", flexDirection: "column" }}>
        <div style={{ padding: "28px 28px 20px", borderBottom: `1px solid ${C.border}`, display: "flex", justifyContent: "space-between", alignItems: "center" }}>
          <div>
            <div style={{ fontSize: "18px", fontWeight: "700", color: C.text, marginBottom: "3px" }}>📚 أرشيف الحلقات</div>
            <div style={{ color: C.textMuted, fontSize: "12px" }}>{eps.length} حلقة محفوظة</div>
          </div>
          <button onClick={onClose} style={{ background: "none", border: "none", color: C.textMuted, fontSize: "20px", cursor: "pointer" }}>✕</button>
        </div>

        <div style={{ flex: 1, overflowY: "auto", padding: "20px 28px" }}>
          {eps.length === 0 ? (
            <div style={{ textAlign: "center", padding: "60px 0", color: C.textMuted, fontSize: "14px" }}>
              <div style={{ fontSize: "40px", marginBottom: "12px" }}>📭</div>
              لا توجد حلقات محفوظة بعد
            </div>
          ) : selected ? (
            <div>
              <button onClick={() => setSelected(null)} style={{ background: "none", border: "none", color: C.textMuted, fontSize: "13px", cursor: "pointer", marginBottom: "16px", padding: 0 }}>← العودة للقائمة</button>
              <div style={{ display: "flex", alignItems: "center", gap: "8px", marginBottom: "8px" }}>
                <TypeBadge type={selected.type} />
                <span style={{ fontSize: "16px", fontWeight: "700", color: C.text }}>{selected.podcast}</span>
              </div>
              <div style={{ color: C.textMuted, fontSize: "12px", marginBottom: "16px" }}>
                {new Date(selected.date).toLocaleDateString("ar")} · {selected.duration} · {selected.studioType === "video" ? "🎬 مصوّر" : "🎙 صوتي"}
              </div>
              {selected.link && (
                <div style={{ marginBottom: "16px" }}>
                  <Lbl>رابط الحلقة</Lbl>
                  <a href={selected.link} target="_blank" rel="noreferrer" style={{ color: C.accent, fontSize: "13px", wordBreak: "break-all" }}>{selected.link}</a>
                </div>
              )}
              <Lbl>الموضوع</Lbl>
              <div style={{ color: C.text, fontSize: "13px", marginBottom: "16px", lineHeight: "1.7" }}>{selected.topic}</div>
              {selected.script && (
                <div>
                  <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: "10px" }}>
                    <Lbl>السكريبت</Lbl>
                    <CopyBtn text={selected.script} small />
                  </div>
                  <OutputBox content={selected.script} />
                </div>
              )}
              {selected.notes && (
                <div style={{ marginTop: "16px" }}>
                  <Lbl>ملاحظات</Lbl>
                  <div style={{ color: C.textMuted, fontSize: "13px", lineHeight: "1.7" }}>{selected.notes}</div>
                </div>
              )}
            </div>
          ) : (
            <div style={{ display: "grid", gap: "10px" }}>
              {eps.map(ep => (
                <div key={ep.id} onClick={() => setSelected(ep)} style={{
                  background: C.card, border: `1px solid ${C.border}`, borderRadius: "10px",
                  padding: "16px 18px", cursor: "pointer", transition: "border-color 0.2s",
                  display: "flex", justifyContent: "space-between", alignItems: "center",
                }}>
                  <div>
                    <div style={{ display: "flex", alignItems: "center", gap: "8px", marginBottom: "6px" }}>
                      <TypeBadge type={ep.type} />
                      <span style={{ color: C.text, fontWeight: "700", fontSize: "14px" }}>{ep.podcast}</span>
                    </div>
                    <div style={{ color: C.textMuted, fontSize: "12px" }}>
                      {ep.topic.slice(0, 60)}{ep.topic.length > 60 ? "..." : ""} · {new Date(ep.date).toLocaleDateString("ar")}
                    </div>
                    {ep.link && <div style={{ color: C.accent, fontSize: "11px", marginTop: "4px" }}>🔗 منشور</div>}
