// ─── MARKETING SCREEN ─────────────────────────────────────────────────────────
function MarketingScreen({ episode, onNavigate }) {
  const [episodeLink, setEpisodeLink] = useState(episode?.link || "");
  const [activeTab, setActiveTab] = useState("description");
  const [outputs, setOutputs] = useState({});
  const [loading, setLoading] = useState("");
  const [copied, setCopied] = useState("");
  const [savingDrive, setSavingDrive] = useState(false);
  const [driveMsg, setDriveMsg] = useState("");

  const tabs = [
    { id: "description", label: "وصف الحلقة" },
    { id: "social", label: "السوشيال ميديا" },
    { id: "email", label: "نشرة بريدية" },
    { id: "titles", label: "عناوين بديلة" },
  ];

  const generateTab = async (tab) => {
    if (!episode) return;
    setLoading(tab);
    const base = `البودكاست: "${episode.name}" | النوع: ${typeConfig[episode.type]?.label}\nالموضوع: ${episode.topic}\n${episodeLink ? `رابط الحلقة: ${episodeLink}` : ""}\n\n`;

    const prompts = {
      description: base + `اكتب وصفاً احترافياً لهذه الحلقة يُستخدم على Spotify وAnghami وApple Podcasts. الوصف:\n- من ٣ إلى ٥ فقرات\n- يبدأ بجملة تشويقية قوية\n- يوضح ما سيستفيده المستمع\n- يتضمن الكلمات المفتاحية المناسبة\n- يختتم بدعوة للاشتراك والمتابعة`,
      social: base + `اكتب محتوى السوشيال ميديا لهذه الحلقة:\n\n1. تغريدة/منشور تويتر X (أقل من 280 حرف) — مباشرة وجذابة\n2. منشور انستقرام — أطول مع هاشتاقات مناسبة (٥–١٠ هاشتاقات)\n3. منشور لينكدإن — احترافي يستهدف جمهور محترفين\n4. مقتطف مميز من الحلقة (اقتباس يصلح للتصميم الجرافيكي)\n\nلكل منصة: اكتب المحتوى جاهزاً للنسخ والنشر مباشرةً.`,
      email: base + `اكتب نشرة بريدية لإعلام المشتركين بهذه الحلقة الجديدة:\n- سطر موضوع جذاب (subject line)\n- مقدمة ترحيب قصيرة\n- ملخص الحلقة في ٣ نقاط رئيسية\n- أبرز لحظة أو اقتباس من الحلقة\n- زر/رابط للاستماع\n- خاتمة ودية`,
      titles: base + `اقترح ١٠ عناوين بديلة لهذه الحلقة:\n- ٣ عناوين تثير الفضول\n- ٣ عناوين تركز على الفائدة المباشرة\n- ٢ عناوين تستخدم الأرقام\n- ٢ عناوين قصيرة ومباشرة\n\nلكل عنوان: اكتب سبب اختياره في جملة.`,
    };

    try {
      const text = await callClaude("أنت خبير تسويق بودكاست عربي. تكتب محتوى تسويقياً جذاباً وفعّالاً. ردودك دائماً بالعربية.", prompts[tab]);
      setOutputs(o => ({ ...o, [tab]: text }));
    } catch (e) { setOutputs(o => ({ ...o, [tab]: `خطأ: ${e.message}` })); }
    setLoading("");
  };

  const saveToDrive = async () => {
    if (!episode) return;
    setSavingDrive(true);
    setDriveMsg("");
    try {
      const content = [
        `# ${episode.name}`,
        `**الموضوع:** ${episode.topic}`,
        `**النوع:** ${typeConfig[episode.type]?.label}`,
        `**المدة:** ${episode.duration}`,
        episodeLink ? `**رابط الحلقة:** ${episodeLink}` : "",
        "",
        "---",
        "",
        "## السكريبت",
        episode.script || "لم يُولَّد بعد",
        "",
        outputs.description ? `## وصف الحلقة\n${outputs.description}` : "",
        outputs.social ? `## محتوى السوشيال\n${outputs.social}` : "",
        outputs.email ? `## النشرة البريدية\n${outputs.email}` : "",
        outputs.titles ? `## عناوين بديلة\n${outputs.titles}` : "",
      ].filter(Boolean).join("\n");

      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: API_HEADERS,
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 100,
          system: "You help save podcast content to Google Drive.",
          messages: [{ role: "user", content: "confirm" }],
          mcp_servers: [{ type: "url", url: "https://drivemcp.googleapis.com/mcp/v1", name: "gdrive" }],
        }),
      });

      // Fallback: download as file if Drive MCP not available
      const blob = new Blob([content], { type: "text/plain;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = `${episode.name || "podcast"}-${new Date().toLocaleDateString("ar")}.md`;
      a.click();
      URL.revokeObjectURL(url);
      setDriveMsg("✓ تم تحميل الملف — يمكنك رفعه يدوياً على Drive");
    } catch (e) {
      setDriveMsg(`تعذّر الحفظ: ${e.message}`);
    }
    setSavingDrive(false);
  };

  return (
    <div>
      <SectionTitle icon="◐" title="التسويق والنشر" subtitle="توليد محتوى تسويقي جاهز لكل المنصات" />

      {/* Episode Link */}
      <div style={{ marginBottom: "20px" }}>
        <Label>رابط الحلقة (اختياري)</Label>
        <TInput value={episodeLink} onChange={setEpisodeLink} placeholder="https://open.spotify.com/episode/..." />
      </div>

      {!episode && (
        <Card style={{ textAlign: "center", padding: "36px", marginBottom: "20px" }}>
          <div style={{ color: COLORS.textMuted, fontSize: "14px" }}>أنشئ حلقة أولاً من صفحة "إنشاء"</div>
        </Card>
      )}

      {/* Tabs */}
      <div style={{ display: "flex", gap: "4px", background: COLORS.bg, border: `1px solid ${COLORS.border}`, borderRadius: "8px", padding: "4px", marginBottom: "20px", overflowX: "auto" }}>
        {tabs.map(t => (
          <button key={t.id} onClick={() => setActiveTab(t.id)} style={{
            flex: 1, minWidth: "80px", background: activeTab === t.id ? COLORS.surface : "transparent",
            border: activeTab === t.id ? `1px solid ${COLORS.border}` : "1px solid transparent",
            borderRadius: "6px", padding: "8px 6px", color: activeTab === t.id ? COLORS.text : COLORS.textMuted,
            fontFamily: "'Noto Kufi Arabic',sans-serif", fontWeight: "600", fontSize: "12px",
            cursor: "pointer", whiteSpace: "nowrap",
          }}>{t.label}</button>
        ))}
      </div>

      <Btn onClick={() => generateTab(activeTab)} disabled={!episode || !!loading} full color={COLORS.accent}>
        {loading === activeTab ? "جارٍ التوليد..." : `توليد ${tabs.find(t => t.id === activeTab)?.label}`}
      </Btn>

      {loading === activeTab && <Spinner />}

      {outputs[activeTab] && loading !== activeTab && (
        <div style={{ marginTop: "16px" }}>
          <OutputBox
            text={outputs[activeTab]}
            copied={copied === activeTab}
            onCopy={() => { navigator.clipboard.writeText(outputs[activeTab]); setCopied(activeTab); setTimeout(() => setCopied(""), 2000); }}
          />
        </div>
      )}

      {/* Save to Drive */}
      <div style={{ marginTop: "24px", borderTop: `1px solid ${COLORS.border}`, paddingTop: "20px" }}>
        <div style={{ fontSize: "13px", color: COLORS.textMuted, marginBottom: "12px" }}>
          حفظ كل محتوى الحلقة (سكريبت + تسويق) في ملف واحد
        </div>
        <Btn onClick={saveToDrive} disabled={!episode || savingDrive} variant="outline" full>
          {savingDrive ? "جارٍ الحفظ..." : "⬇ تنزيل ملف الحلقة"}
        </Btn>
        {driveMsg && (
          <div>
            <div style={{ marginTop: "10px", fontSize: "12px", color: COLORS.success }}>{driveMsg}</div>
            <div style={{
              marginTop: "14px", padding: "14px 18px", borderRadius: "10px",
              background: `${COLORS.success}15`, border: `1px solid ${COLORS.success}40`,
              display: "flex", alignItems: "center", justifyContent: "space-between",
            }}>
              <div>
                <div style={{ color: COLORS.success, fontWeight: "700", fontSize: "13px", marginBottom: "2px" }}>✓ الحلقة مكتملة</div>
                <div style={{ color: COLORS.textMuted, fontSize: "11px" }}>شاهد جميع حلقاتك المحفوظة</div>
              </div>
              <Btn onClick={() => onNavigate("episodes")} color={COLORS.success}>حلقاتي ←</Btn>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

