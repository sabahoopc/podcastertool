// ─── STYLE MODAL ──────────────────────────────────────────────────────────────
function StyleModal({ onClose }) {
  const [profile, setProfile] = useState(() => getStyle() || {});
  const [sample, setSample] = useState("");
  const [analyzing, setAnalyzing] = useState(false);
  const [saved, setSaved] = useState(false);
  const upd = (k, v) => setProfile(p => ({ ...p, [k]: v }));

  const analyze = async () => {
    if (!sample.trim()) return;
    setAnalyzing(true);
    try {
      const raw = await callClaude(
        "أنت محلل أسلوب كتابي. ردودك JSON فقط بدون أي نص إضافي أو backticks.",
        `حلّل هذا السكريبت وأجب بـ JSON فقط:\n{"tone":"النبرة","opening":"طريقة البداية","language":"نوع اللغة","structure":"بناء المحتوى","closing":"طريقة الختام","distinctive":"ما يميزه"}\n\nالسكريبت: ${sample}`,
        800
      );
      const parsed = JSON.parse(raw.trim());
      setProfile(p => ({ ...p, ...parsed, analyzed: true }));
    } catch { }
    setAnalyzing(false);
  };

  const save = () => {
    localStorage.setItem(STYLE_KEY, JSON.stringify({ ...profile, lastUpdated: new Date().toISOString() }));
    setSaved(true);
    setTimeout(() => { setSaved(false); onClose(); }, 1000);
  };

  return (
    <div style={{ position: "fixed", inset: 0, background: "#0a0a0ff2", display: "flex", alignItems: "center", justifyContent: "center", zIndex: 200, padding: "16px" }}>
      <div style={{ background: COLORS.surface, border: `1px solid ${COLORS.border}`, borderRadius: "14px", width: "100%", maxWidth: "580px", maxHeight: "90vh", overflowY: "auto", padding: "28px" }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: "24px" }}>
          <div>
            <div style={{ fontSize: "18px", fontWeight: "700", color: COLORS.text }}>✦ ملف أسلوبي</div>
            <div style={{ color: COLORS.textMuted, fontSize: "12px", marginTop: "3px" }}>يُطبَّق تلقائياً في كل سكريبت</div>
          </div>
          <button onClick={onClose} style={{ background: "none", border: "none", color: COLORS.textMuted, fontSize: "20px", cursor: "pointer" }}>✕</button>
        </div>

        <Card style={{ marginBottom: "20px", borderColor: `${COLORS.accent}40` }}>
          <div style={{ fontSize: "12px", color: COLORS.accent, fontWeight: "700", marginBottom: "8px" }}>استخراج تلقائي من سكريبت سابق</div>
          <TInput value={sample} onChange={setSample} placeholder="الصق مقطعاً من حلقة سابقة..." multiline rows={3} />
          <div style={{ marginTop: "10px", display: "flex", alignItems: "center", gap: "12px" }}>
            <Btn onClick={analyze} disabled={!sample.trim() || analyzing} small color={COLORS.accent}>{analyzing ? "جارٍ التحليل..." : "تحليل وملء تلقائي"}</Btn>
            {profile.analyzed && <span style={{ fontSize: "11px", color: COLORS.success }}>✓ تم الاستخراج</span>}
          </div>
        </Card>

        <div style={{ display: "grid", gap: "16px" }}>
          {[
            { k: "tone", l: "النبرة العامة", p: "دافئ، تحليلي، حماسي..." },
            { k: "opening", l: "طريقة الافتتاح", p: "سؤال تشويقي، قصة، إحصائية..." },
            { k: "language", l: "نوع اللغة", p: "فصحى / خليجية / مزيج..." },
            { k: "closing", l: "طريقة الختام", p: "سؤال للمتابعين، توصية..." },
            { k: "distinctive", l: "بصمتك المميزة", p: "ما يجعل أسلوبك مختلفاً..." },
          ].map(f => (
            <div key={f.k}>
              <Label>{f.l}</Label>
              <TInput value={profile[f.k] || ""} onChange={v => upd(f.k, v)} placeholder={f.p} />
            </div>
          ))}
          <div>
            <Label>بناء المحتوى وتدفقه</Label>
            <TInput value={profile.structure || ""} onChange={v => upd("structure", v)} placeholder="كيف تنظم أفكارك داخل الحلقة..." multiline rows={3} />
          </div>
        </div>

        <div style={{ display: "flex", justifyContent: "space-between", marginTop: "24px" }}>
          <Btn variant="outline" onClick={onClose}>إلغاء</Btn>
          <Btn onClick={save} disabled={!(profile.tone || profile.opening)}>{saved ? "✓ تم الحفظ" : "حفظ الملف"}</Btn>
        </div>
      </div>
    </div>
  );
}

// ─── CREATE SCREEN (Steps 1–3) ────────────────────────────────────────────────
function CreateScreen({ onEpisodeReady, onNavigate }) {
  const [step, setStep] = useState(0);
  const [data, setData] = useState({ name: "", type: "", duration: "", frequency: "", topic: "", hostCount: 2 });
  const [script, setScript] = useState("");
  const [loading, setLoading] = useState(false);
  const [copied, setCopied] = useState(false);

  const styleBlock = () => {
    const s = getStyle();
    if (!s) return "";
    const lines = [
      s.tone && `النبرة: ${s.tone}`,
      s.opening && `طريقة الافتتاح: ${s.opening}`,
      s.language && `اللغة: ${s.language}`,
      s.structure && `بناء المحتوى: ${s.structure}`,
      s.closing && `طريقة الختام: ${s.closing}`,
      s.distinctive && `البصمة: ${s.distinctive}`,
    ].filter(Boolean);
    return lines.length ? `\n\n━━━ أسلوب المذيع الشخصي — التزم به تماماً ━━━\n${lines.join("\n")}\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━` : "";
  };

  const buildPrompt = () => {
    const header = `البودكاست: "${data.name}" | النوع: ${typeConfig[data.type].label} | المدة: ${data.duration} | النشر: ${data.frequency}${styleBlock()}\n\n`;
    if (data.type === "solo")
      return header + `الموضوع: ${data.topic}\n\nاكتب سكريبت كامل ومفصّل جاهز للتسجيل مباشرةً — ليس نقاطاً أو مخططاً. يشمل:\n١- مقدمة جذابة كاملة (تشويق + ترحيب + تعريف بالموضوع)\n٢- عرض الموضوع بتفصيل مع انتقالات طبيعية\n٣- تعمق في كل نقطة مع أمثلة أو قصص أو أرقام\n٤- خاتمة قوية مع call to action\nضع [توقف] عند الانتقالات و[تأكيد] عند النقاط المهمة. الطول يتناسب مع ${data.duration}.`;
    if (data.type === "group") {
      const h = data.hostCount || 2;
      const names = ["م١", "م٢", "م٣", "م٤", "م٥"].slice(0, h).join("، ");
      return header + `الموضوع: ${data.topic}\nعدد المذيعين: ${h}\n\nاكتب سكريبت حوار جماعي كامل موزع على (${names})، كل جملة مكتوبة بالكامل. يشمل:\n١- مقدمة م١ يعرّف فيها بالبودكاست والمذيعين والموضوع\n٢- حوار متدفق — لكل مذيع زاوية مختلفة مع تبادل طبيعي\n٣- نقاط توافق وخلاف بين المذيعين\n٤- خاتمة مشتركة\nالطول يتناسب مع ${data.duration}.`;
    }
    return header + `الضيف/الموضوع: ${data.topic}\n\nاكتب قائمة أسئلة احترافية كاملة:\n١- ٣ أسئلة تمهيدية (التعريف بالضيف ومساره)\n٢- ٦–٨ أسئلة جوهرية متدرجة من السطحي للعمق\n٣- ٣ أسئلة استفزازية تفتح نقاشاً حقيقياً\n٤- سؤال ختامي مميز\nلكل سؤال: اكتبه كاملاً + هدفه + أسئلة متابعة محتملة.`;
  };

  const generate = async () => {
    setLoading(true);
    setScript("");
    try {
      const text = await callClaude(
        "أنت خبير في صناعة البودكاست العربي. تكتب سكريبتات كاملة جاهزة للتسجيل. إذا وُجد ملف أسلوب شخصي، التزم به في كل جملة. ردودك دائماً بالعربية.",
        buildPrompt()
      );
      setScript(text);
      // auto-save episode draft
      const ep = {
        id: Date.now().toString(),
        name: data.name, type: data.type, duration: data.duration,
        frequency: data.frequency, topic: data.topic,
        script: text, createdAt: new Date().toISOString(),
        status: "draft",
      };
      saveEpisode(ep);
      onEpisodeReady(ep);
    } catch (e) { setScript(`خطأ: ${e.message}`); }
    setLoading(false);
  };

  const cfg = data.type ? typeConfig[data.type] : { color: COLORS.accent };

  return (
    <div>
      <StepDots current={step} total={3} />

      {/* Step 0 */}
      {step === 0 && (
        <div>
          <SectionTitle icon="◎" title="هوية البودكاست" subtitle="ابدأ بتحديد اسم البودكاست وطبيعته" />
          <div style={{ marginBottom: "20px" }}>
            <Label>اسم البودكاست</Label>
            <TInput value={data.name} onChange={v => setData({ ...data, name: v })} placeholder="مثال: بودكاست مدى، صوت العقل..." />
          </div>
          <Label>نوع البودكاست</Label>
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: "10px", marginBottom: "28px" }}>
            {Object.entries(typeConfig).map(([key, c]) => {
              const sel = data.type === key;
              return (
                <div key={key} onClick={() => setData({ ...data, type: key })} style={{
                  border: `2px solid ${sel ? c.color : COLORS.border}`, borderRadius: "10px",
                  padding: "16px 12px", cursor: "pointer", background: sel ? `${c.color}12` : COLORS.bg,
                  transition: "all 0.2s", textAlign: "center",
                }}>
                  <div style={{ fontSize: "22px", marginBottom: "6px" }}>{c.icon}</div>
                  <div style={{ color: sel ? c.color : COLORS.text, fontWeight: "700", fontSize: "14px", marginBottom: "4px" }}>{c.label}</div>
                  <div style={{ color: COLORS.textMuted, fontSize: "11px", lineHeight: "1.5" }}>{c.desc}</div>
                </div>
              );
            })}
          </div>
          <div style={{ textAlign: "left" }}>
            <Btn onClick={() => setStep(1)} disabled={!data.name || !data.type}>التالي ←</Btn>
          </div>
        </div>
      )}

      {/* Step 1 */}
      {step === 1 && (
        <div>
          <SectionTitle icon="◈" title="تفاصيل الحلقة" />
          <div style={{ display: "flex", alignItems: "center", gap: "10px", marginBottom: "20px" }}>
            <TypeBadge type={data.type} />
            <span style={{ fontWeight: "700", color: COLORS.text }}>{data.name}</span>
          </div>
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "16px", marginBottom: "18px" }}>
            <div>
              <Label>مدة الحلقة</Label>
              <TSelect value={data.duration} onChange={v => setData({ ...data, duration: v })} options={durationOptions} placeholder="اختر المدة" />
            </div>
            <div>
              <Label>تكرار النشر</Label>
              <TSelect value={data.frequency} onChange={v => setData({ ...data, frequency: v })} options={frequencyOptions} placeholder="كم مرة؟" />
            </div>
          </div>
          {data.type === "group" && (
            <div style={{ marginBottom: "18px" }}>
              <Label>عدد المذيعين</Label>
              <div style={{ display: "flex", gap: "8px" }}>
                {[2, 3, 4, 5].map(n => (
                  <div key={n} onClick={() => setData({ ...data, hostCount: n })} style={{
                    border: `2px solid ${data.hostCount === n ? cfg.color : COLORS.border}`,
                    borderRadius: "8px", padding: "9px 18px", cursor: "pointer",
                    color: data.hostCount === n ? cfg.color : COLORS.textMuted, fontWeight: "700",
                    background: data.hostCount === n ? `${cfg.color}15` : "transparent",
                  }}>{n}</div>
                ))}
              </div>
            </div>
          )}
          <div style={{ marginBottom: "24px" }}>
            <Label>{data.type === "solo" ? "الموضوع أو الفكرة الكاملة" : data.type === "group" ? "موضوع النقاش وأبرز المحاور" : "موضوع الحلقة وتفاصيل الضيف"}</Label>
            <TInput value={data.topic} onChange={v => setData({ ...data, topic: v })} multiline rows={5}
              placeholder={data.type === "solo" ? "اكتب الفكرة بشكل موسع..." : data.type === "group" ? "ما الموضوع الذي ستناقشونه؟" : "من الضيف؟ وما المحور؟"} />
          </div>
          <div style={{ display: "flex", justifyContent: "space-between" }}>
            <Btn variant="outline" onClick={() => setStep(0)}>← رجوع</Btn>
            <Btn onClick={() => setStep(2)} disabled={!data.duration || !data.frequency || !data.topic}>التالي ←</Btn>
          </div>
        </div>
      )}

      {/* Step 2 - Generate */}
      {step === 2 && (
        <div>
