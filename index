import { useState, useEffect } from "react";

const C = {
  bg: "#0a0a0f", surface: "#12121a", card: "#1a1a26", border: "#2a2a3e",
  accent: "#c8a96e", accentDim: "#8a7048", accentGlow: "#c8a96e22",
  text: "#e8e4d8", textMuted: "#7a7890", textDim: "#4a4860",
  solo: "#4e9e8f", group: "#7e6db5", interview: "#c05c5c", success: "#4e9e6f",
};

const TYPE_CFG = {
  solo: { label: "فردي", color: C.solo, icon: "◎", desc: "مذيع واحد يقدم المحتوى بمفرده" },
  group: { label: "جماعي", color: C.group, icon: "◈", desc: "أكثر من مذيع يناقشون موضوعاً واحداً" },
  interview: { label: "حواري", color: C.interview, icon: "◇", desc: "استضافة ضيف والتحاور معه" },
};

const FREQ_OPTS = ["يومي", "أسبوعي", "نصف شهري", "شهري", "غير منتظم"];
const DUR_OPTS = ["١٠–٢٠ دقيقة", "٢٠–٤٠ دقيقة", "٤٠–٦٠ دقيقة", "٦٠–٩٠ دقيقة", "أكثر من ٩٠ دقيقة"];
const STYLE_KEY = "ps_style_v1";
const EPS_KEY = "ps_episodes_v1";

const apiCall = async (system, userMsg, maxTokens = 1500) => {
  const res = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json", "anthropic-dangerous-direct-browser-access": "true" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514", max_tokens: maxTokens,
      system, messages: [{ role: "user", content: userMsg }],
    }),
  });
  if (!res.ok) throw new Error(`${res.status}`);
  const json = await res.json();
  return json.content?.filter(b => b.type === "text").map(b => b.text).join("\n") || "";
};

// ─── Base UI ──────────────────────────────────────────────────────────────────
const Lbl = ({ children, hint }) => (
  <div style={{ marginBottom: "10px" }}>
    <span style={{ fontSize: "11px", letterSpacing: "0.14em", color: C.textMuted, textTransform: "uppercase" }}>{children}</span>
    {hint && <span style={{ fontSize: "11px", color: C.textDim, marginRight: "8px" }}>{hint}</span>}
  </div>
);

const Inp = ({ value, onChange, placeholder, multiline, rows = 5, disabled }) => {
  const s = {
    width: "100%", background: disabled ? C.surface : C.bg, border: `1px solid ${C.border}`,
    borderRadius: "6px", padding: "13px 15px", color: C.text,
    fontFamily: "'Noto Kufi Arabic', sans-serif", fontSize: "14px",
    outline: "none", resize: multiline ? "vertical" : "none",
    direction: "rtl", boxSizing: "border-box", lineHeight: "1.8",
    opacity: disabled ? 0.6 : 1,
  };
  return multiline
    ? <textarea value={value} onChange={e => onChange(e.target.value)} placeholder={placeholder} rows={rows} style={s} disabled={disabled} />
    : <input value={value} onChange={e => onChange(e.target.value)} placeholder={placeholder} style={s} disabled={disabled} />;
};

const Sel = ({ value, onChange, options, placeholder }) => (
  <select value={value} onChange={e => onChange(e.target.value)} style={{
    width: "100%", background: C.bg, border: `1px solid ${C.border}`, borderRadius: "6px",
    padding: "13px 15px", color: value ? C.text : C.textMuted,
    fontFamily: "'Noto Kufi Arabic', sans-serif", fontSize: "14px",
    outline: "none", direction: "rtl", cursor: "pointer", appearance: "none",
  }}>
    <option value="" disabled>{placeholder}</option>
    {options.map(o => <option key={o} value={o}>{o}</option>)}
  </select>
);

const Btn = ({ children, onClick, color, disabled, variant = "fill", small, full }) => {
  const base = color || C.accent;
  return (
    <button onClick={onClick} disabled={disabled} style={{
      background: variant === "fill" ? base : "transparent",
      border: `1px solid ${variant === "fill" ? base : C.border}`,
      borderRadius: "6px", color: variant === "fill" ? "#0a0a0f" : C.textMuted,
      fontFamily: "'Noto Kufi Arabic', sans-serif", fontWeight: "700",
      fontSize: small ? "12px" : "14px", padding: small ? "7px 16px" : "12px 26px",
      cursor: disabled ? "not-allowed" : "pointer", opacity: disabled ? 0.4 : 1,
      transition: "all 0.15s", width: full ? "100%" : "auto",
    }}>{children}</button>
  );
};

const Card = ({ children, style, accent }) => (
  <div style={{
    background: C.card, border: `1px solid ${accent ? `${accent}50` : C.border}`,
    borderRadius: "12px", padding: "24px", ...style,
  }}>{children}</div>
);

const Spinner = ({ color }) => (
  <div style={{
    width: "36px", height: "36px", border: `3px solid ${C.border}`,
    borderTop: `3px solid ${color || C.accent}`, borderRadius: "50%",
    animation: "spin 0.8s linear infinite", margin: "0 auto 16px",
  }} />
);

const CopyBtn = ({ text, small }) => {
  const [copied, setCopied] = useState(false);
  return (
    <Btn variant="outline" small={small} onClick={() => {
      navigator.clipboard.writeText(text);
      setCopied(true);
      setTimeout(() => setCopied(false), 2000);
    }}>{copied ? "✓ تم النسخ" : "نسخ"}</Btn>
  );
};

const TypeBadge = ({ type }) => {
  const cfg = TYPE_CFG[type];
  return (
    <span style={{
      display: "inline-flex", alignItems: "center", gap: "5px",
      background: `${cfg.color}20`, border: `1px solid ${cfg.color}`,
      borderRadius: "5px", padding: "3px 10px", color: cfg.color, fontSize: "12px", fontWeight: "700",
    }}>{cfg.icon} {cfg.label}</span>
  );
};

const StepDots = ({ current, total }) => (
  <div style={{ display: "flex", gap: "6px", justifyContent: "center", marginBottom: "36px" }}>
    {Array.from({ length: total }).map((_, i) => (
      <div key={i} style={{
        width: i === current ? "26px" : "7px", height: "7px", borderRadius: "4px",
        background: i === current ? C.accent : i < current ? C.accentDim : C.border,
        transition: "all 0.3s",
      }} />
    ))}
  </div>
);

const OutputBox = ({ content }) => (
  <div style={{
    background: C.bg, border: `1px solid ${C.border}`, borderRadius: "10px",
    padding: "20px", color: C.text, fontSize: "14px", lineHeight: "2",
    direction: "rtl", whiteSpace: "pre-wrap", fontFamily: "'Noto Kufi Arabic', sans-serif",
    maxHeight: "420px", overflowY: "auto",
  }}>{content}</div>
);

// ─── Style Modal ──────────────────────────────────────────────────────────────
function StyleModal({ onClose }) {
  const [profile, setProfile] = useState(() => { try { return JSON.parse(localStorage.getItem(STYLE_KEY)) || {}; } catch { return {}; } });
  const [sample, setSample] = useState("");
  const [analyzing, setAnalyzing] = useState(false);
  const [saved, setSaved] = useState(false);
  const upd = (k, v) => setProfile(p => ({ ...p, [k]: v }));

  const analyze = async () => {
    if (!sample.trim()) return;
    setAnalyzing(true);
    try {
      const raw = await apiCall(
        "أنت محلل أسلوب كتابي. ردودك JSON فقط بدون أي نص إضافي أو backticks.",
        `حلّل هذا السكريبت واستخرج ملف الأسلوب. أجب بـ JSON فقط:\n{"tone":"","opening":"","language":"","structure":"","closing":"","distinctive":""}\n\nالسكريبت: ${sample}`
      );
      const parsed = JSON.parse(raw.trim());
      setProfile(p => ({ ...p, ...parsed, analyzed: true }));
    } catch { }
    setAnalyzing(false);
  };

  const save = () => {
    localStorage.setItem(STYLE_KEY, JSON.stringify({ ...profile, lastUpdated: new Date().toISOString() }));
    setSaved(true);
    setTimeout(() => { setSaved(false); onClose(); }, 1000);
  };

  return (
    <div style={{ position: "fixed", inset: 0, background: "#0a0a0ff2", backdropFilter: "blur(4px)", display: "flex", alignItems: "center", justifyContent: "center", zIndex: 200, padding: "16px" }}>
      <div style={{ background: C.surface, border: `1px solid ${C.border}`, borderRadius: "16px", width: "100%", maxWidth: "600px", maxHeight: "92vh", overflowY: "auto", padding: "32px" }}>
        <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: "24px" }}>
          <div>
            <div style={{ fontSize: "18px", fontWeight: "700", color: C.text, marginBottom: "4px" }}>✦ ملف أسلوبي</div>
            <div style={{ color: C.textMuted, fontSize: "12px" }}>تُستخدم تلقائياً في كل سكريبت تولّده الأداة</div>
          </div>
          <button onClick={onClose} style={{ background: "none", border: "none", color: C.textMuted, fontSize: "20px", cursor: "pointer" }}>✕</button>
        </div>
        <Card accent={C.accent} style={{ marginBottom: "24px" }}>
          <div style={{ fontSize: "12px", color: C.accent, fontWeight: "700", marginBottom: "8px" }}>استخراج تلقائي من سكريبت سابق</div>
          <Inp value={sample} onChange={setSample} placeholder="الصق مقطعاً من حلقة سابقة..." multiline rows={4} />
          <div style={{ marginTop: "10px", display: "flex", alignItems: "center", gap: "12px" }}>
            <Btn onClick={analyze} disabled={!sample.trim() || analyzing} small color={C.accent}>{analyzing ? "جارٍ التحليل..." : "تحليل وملء تلقائي"}</Btn>
            {profile.analyzed && <span style={{ fontSize: "11px", color: C.success }}>✓ تم الاستخراج</span>}
          </div>
        </Card>
        <div style={{ display: "grid", gap: "16px" }}>
          {[
            { k: "tone", l: "النبرة العامة", h: "(دافئ، تحليلي، حماسي...)", p: "كيف تصف طريقة حديثك؟" },
            { k: "opening", l: "طريقة الافتتاح", h: "(سؤال، قصة، إحصائية...)", p: "كيف تبدأ حلقاتك عادةً؟" },
            { k: "language", l: "نوع اللغة", h: "(فصحى / خليجية / مصرية / مزيج)", p: "ما اللهجة أو المستوى اللغوي؟" },
            { k: "closing", l: "طريقة الختام", h: "(سؤال للمتابعين، دعوة...)", p: "كيف تنهي حلقاتك عادةً؟" },
            { k: "distinctive", l: "بصمتك المميزة", h: "", p: "ما الذي يميز أسلوبك؟" },
          ].map(f => (
            <div key={f.k}><Lbl hint={f.h}>{f.l}</Lbl><Inp value={profile[f.k] || ""} onChange={v => upd(f.k, v)} placeholder={f.p} /></div>
          ))}
          <div><Lbl hint="كيف تنظم أفكارك">بناء المحتوى</Lbl><Inp value={profile.structure || ""} onChange={v => upd("structure", v)} placeholder="مثال: أبدأ بسؤال ثم أبني إجابته..." multiline rows={3} /></div>
        </div>
        <div style={{ display: "flex", justifyContent: "space-between", marginTop: "28px" }}>
          <Btn variant="outline" onClick={onClose}>إلغاء</Btn>
          <Btn onClick={save} disabled={!(profile.tone || profile.opening || profile.structure)}>{saved ? "✓ تم الحفظ" : "حفظ الملف"}</Btn>
        </div>
      </div>
    </div>
  );
}

// ─── Step 1: Identity ─────────────────────────────────────────────────────────
function Step1({ data, setData, onNext }) {
  return (
    <div>
      <div style={{ marginBottom: "32px" }}>
        <div style={{ fontSize: "20px", fontWeight: "700", color: C.text, marginBottom: "6px" }}>هوية البودكاست</div>
        <div style={{ color: C.textMuted, fontSize: "13px" }}>ابدأ بتحديد اسم البودكاست وطبيعته</div>
      </div>
      <div style={{ marginBottom: "24px" }}><Lbl>اسم البودكاست</Lbl><Inp value={data.name} onChange={v => setData({ ...data, name: v })} placeholder="مثال: بودكاست مدى، صوت العقل..." /></div>
      <div style={{ marginBottom: "12px" }}><Lbl>نوع البودكاست</Lbl></div>
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr 1fr", gap: "10px", marginBottom: "32px" }}>
        {Object.entries(TYPE_CFG).map(([key, cfg]) => {
          const sel = data.type === key;
          return (
            <div key={key} onClick={() => setData({ ...data, type: key })} style={{
              border: `2px solid ${sel ? cfg.color : C.border}`, borderRadius: "10px",
              padding: "18px 12px", cursor: "pointer", background: sel ? `${cfg.color}12` : C.bg,
              transition: "all 0.2s", textAlign: "center",
            }}>
              <div style={{ fontSize: "24px", marginBottom: "6px" }}>{cfg.icon}</div>
              <div style={{ color: sel ? cfg.color : C.text, fontWeight: "700", fontSize: "14px", marginBottom: "4px" }}>{cfg.label}</div>
              <div style={{ color: C.textMuted, fontSize: "11px", lineHeight: "1.5" }}>{cfg.desc}</div>
            </div>
          );
        })}
      </div>
      <div style={{ textAlign: "left" }}><Btn onClick={onNext} disabled={!data.name || !data.type}>التالي ←</Btn></div>
    </div>
  );
}

// ─── Step 2: Episode Details ──────────────────────────────────────────────────
function Step2({ data, setData, onNext, onBack }) {
  const cfg = TYPE_CFG[data.type];
  return (
    <div>
      <div style={{ marginBottom: "32px" }}>
        <div style={{ display: "flex", alignItems: "center", gap: "10px", marginBottom: "6px" }}>
          <TypeBadge type={data.type} />
          <span style={{ fontSize: "18px", fontWeight: "700", color: C.text }}>{data.name}</span>
        </div>
        <div style={{ color: C.textMuted, fontSize: "13px" }}>تفاصيل الحلقة وبيئة الإنتاج</div>
      </div>

      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "16px", marginBottom: "20px" }}>
        <div><Lbl>مدة الحلقة</Lbl><Sel value={data.duration} onChange={v => setData({ ...data, duration: v })} options={DUR_OPTS} placeholder="اختر المدة" /></div>
        <div><Lbl>تكرار النشر</Lbl><Sel value={data.frequency} onChange={v => setData({ ...data, frequency: v })} options={FREQ_OPTS} placeholder="كم مرة تنشر؟" /></div>
      </div>

      {data.type === "group" && (
        <div style={{ marginBottom: "20px" }}>
          <Lbl>عدد المذيعين</Lbl>
          <div style={{ display: "flex", gap: "8px" }}>
            {[2, 3, 4, 5].map(n => (
              <div key={n} onClick={() => setData({ ...data, hostCount: n })} style={{
                border: `2px solid ${data.hostCount === n ? cfg.color : C.border}`, borderRadius: "8px",
                padding: "9px 18px", cursor: "pointer", color: data.hostCount === n ? cfg.color : C.textMuted,
                fontWeight: "700", background: data.hostCount === n ? `${cfg.color}15` : "transparent", transition: "all 0.2s",
              }}>{n}</div>
            ))}
          </div>
        </div>
      )}

      {/* Studio type */}
      <div style={{ marginBottom: "20px" }}>
        <Lbl>نوع الاستوديو</Lbl>
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: "10px" }}>
          {[
            { v: "audio", icon: "🎙", label: "صوتي فقط", desc: "بودكاست صوتي بدون تصوير" },
            { v: "video", icon: "🎬", label: "مصوّر", desc: "تسجيل بالصوت والصورة" },
          ].map(opt => {
            const sel = data.studioType === opt.v;
            return (
              <div key={opt.v} onClick={() => setData({ ...data, studioType: opt.v })} style={{
                border: `2px solid ${sel ? C.accent : C.border}`, borderRadius: "10px",
                padding: "16px", cursor: "pointer", background: sel ? C.accentGlow : C.bg,
                transition: "all 0.2s", textAlign: "center",
              }}>
                <div style={{ fontSize: "22px", marginBottom: "6px" }}>{opt.icon}</div>
                <div style={{ color: sel ? C.accent : C.text, fontWeight: "700", fontSize: "13px", marginBottom: "3px" }}>{opt.label}</div>
                <div style={{ color: C.textMuted, fontSize: "11px" }}>{opt.desc}</div>
              </div>
            );
          })}
        </div>
      </div>

      <div style={{ marginBottom: "28px" }}>
        <Lbl>{data.type === "solo" ? "موضوع الحلقة أو الفكرة الكاملة" : data.type === "group" ? "موضوع النقاش وأبرز المحاور" : "موضوع الحلقة وتفاصيل الضيف"}</Lbl>
        <Inp value={data.topic} onChange={v => setData({ ...data, topic: v })} multiline rows={5}
          placeholder={data.type === "solo" ? "اكتب الفكرة بشكل موسع..." : data.type === "group" ? "ما الموضوع الذي ستناقشونه؟" : "من الضيف؟ وما المحور الذي ستتناوله معه؟"} />
      </div>

      <div style={{ display: "flex", justifyContent: "space-between" }}>
        <Btn variant="outline" onClick={onBack}>← رجوع</Btn>
        <Btn onClick={onNext} disabled={!data.duration || !data.frequency || !data.topic || !data.studioType}>توليد المحتوى ←</Btn>
      </div>
    </div>
  );
}

// ─── Step 3: Script ───────────────────────────────────────────────────────────
function Step3({ data, onNext, onBack }) {
  const [output, setOutput] = useState("");
  const [loading, setLoading] = useState(false);
  const [done, setDone] = useState(false);
  const cfg = TYPE_CFG[data.type];

  const styleBlock = () => {
    try {
      const s = JSON.parse(localStorage.getItem(STYLE_KEY));
      if (!s) return "";
      const lines = [s.tone && `النبرة: ${s.tone}`, s.opening && `الافتتاح: ${s.opening}`, s.language && `اللغة: ${s.language}`, s.structure && `البنية: ${s.structure}`, s.closing && `الختام: ${s.closing}`, s.distinctive && `البصمة: ${s.distinctive}`].filter(Boolean);
      return lines.length ? `\n\n━━━ أسلوب المذيع — التزم به في كل جملة ━━━\n${lines.join("\n")}\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━` : "";
    } catch { return ""; }
  };

  const generate = async () => {
    setLoading(true); setOutput("");
    const header = `البودكاست: "${data.name}" | النوع: ${TYPE_CFG[data.type].label} | المدة: ${data.duration} | النشر: ${data.frequency}${styleBlock()}\n\n`;
    let prompt = "";
    if (data.type === "solo") prompt = header + `الموضوع: ${data.topic}\n\nاكتب سكريبت كامل ومفصّل للتسجيل مباشرةً، يشمل: مقدمة جذابة كاملة، عرض الموضوع مع انتقالات طبيعية، تعمق في كل نقطة مع أمثلة وقصص، خاتمة قوية مع call to action. ضع [توقف] عند الانتقالات و[تأكيد] عند النقاط المهمة. الطول يتناسب مع مدة ${data.duration}.`;
    else if (data.type === "group") {
      const h = data.hostCount || 2;
      const ns = ["م١","م٢","م٣","م٤","م٥"].slice(0,h).join("، ");
      prompt = header + `الموضوع: ${data.topic}\nعدد المذيعين: ${h} (${ns})\n\nاكتب سكريبت حوار جماعي كامل — كل جملة لكل مذيع مكتوبة بالكامل. لكل مذيع زاوية مختلفة، مع توافق وخلاف حقيقي. مقدمة وخاتمة مشتركة. الطول يتناسب مع مدة ${data.duration}.`;
    } else {
      prompt = header + `الضيف/الموضوع: ${data.topic}\n\nاكتب أسئلة احترافية كاملة: ٣ تمهيدية، ٦–٨ جوهرية متدرجة، ٣ استفزازية، سؤال ختامي مميز. لكل سؤال: اكتبه كاملاً وهدفه وأسئلة متابعة محتملة.`;
    }
    try {
      const text = await apiCall("أنت خبير بودكاست عربي. تكتب سكريبتات كاملة جاهزة للتسجيل. التزم بأسلوب المذيع إن وُجد. ردودك بالعربية.", prompt, 4000);
      setOutput(text || "لم يتم إرجاع محتوى، حاول مجدداً.");
      setDone(true);
    } catch (e) { setOutput(`خطأ: ${e.message}`); setDone(true); }
    setLoading(false);
  };

  const hasStyle = (() => { try { const s = JSON.parse(localStorage.getItem(STYLE_KEY)); return !!(s && (s.tone || s.opening)); } catch { return false; } })();

  return (
    <div>
      <div style={{ marginBottom: "20px" }}>
        <div style={{ display: "flex", alignItems: "center", gap: "10px", marginBottom: "4px" }}>
          <TypeBadge type={data.type} />
          <span style={{ fontSize: "17px", fontWeight: "700", color: C.text }}>{data.name}</span>
          {hasStyle && <span style={{ fontSize: "10px", color: C.accent, background: C.accentGlow, border: `1px solid ${C.accentDim}40`, borderRadius: "4px", padding: "2px 7px" }}>✦ أسلوبي</span>}
        </div>
        <span style={{ color: C.textMuted, fontSize: "12px" }}>{data.duration} · {data.frequency} · {data.studioType === "video" ? "🎬 مصوّر" : "🎙 صوتي"}</span>
      </div>

      {!done && !loading && (
        <Card style={{ textAlign: "center", padding: "44px 24px" }}>
          <div style={{ fontSize: "36px", marginBottom: "12px" }}>{data.type === "solo" ? "✦" : data.type === "group" ? "⬡" : "◈"}</div>
          <div style={{ color: C.text, fontSize: "15px", fontWeight: "600", marginBottom: "6px" }}>
            جاهز لتوليد {data.type === "solo" ? "السكريبت" : data.type === "group" ? "سكريبت الحوار الجماعي" : "أسئلة الحلقة"}
          </div>
          <div style={{ color: C.textMuted, fontSize: "12px", marginBottom: "24px" }}>
            {hasStyle ? "سيُكتب بأسلوبك الشخصي المحفوظ" : "سيُولّد المحتوى بناءً على ما أدخلته"}
          </div>
